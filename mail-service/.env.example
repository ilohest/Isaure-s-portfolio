# Config SMTP du mini-service de contact (copier en .env sur le VPS)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=ton-compte@example.com
SMTP_PASS=motdepasse-ou-app-password
OWNER_EMAIL=isaure.lohest@gmail.com

# Port d'écoute local (reverse-proxy Apache → ce port)
PORT=8787

# Optionnel : si le service est servi depuis un autre origin que le site
# (sinon laisser vide, le reverse-proxy Apache sert /api/contact en same-origin)
ALLOWED_ORIGIN=
