<IfModule mod_mime.c>
  RemoveHandler .var
  RemoveType .var
</IfModule>

# Site statique multi-pages (Astro) : chaque route a son propre fichier HTML.
# Toute URL inexistante sert la page 404 générée par Astro, avec un vrai
# statut HTTP 404 (et non plus la home en 200 via un fallback type SPA).
ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  <Files "robots.txt">
    Allow from all
  </Files>
</IfModule>
