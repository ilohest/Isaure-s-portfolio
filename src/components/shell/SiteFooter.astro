---
interface Props {
  isHome?: boolean;
}
const { isHome = false } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class:list={['site-footer', { 'site-footer--home': isHome }]} data-reveal-ignore>
  <div class="site-footer__cta-bar">
    <p class="site-footer__cta-title font-display">Let’s make it happen.</p>
    <a class="site-footer__cta-link portfolio-pill-link" href="/contact">Start a project</a>
  </div>

  <div class="site-footer__inner">
    <div class="site-footer__brand">
      <a class="site-footer__name font-display" href="/">Isaure Lohest</a>
      <p class="site-footer__line">Independent web design, development &amp; visual identity.</p>
      <p class="site-footer__location">Based in Brussels &amp; Barcelona, available remotely</p>
    </div>

    <div class="site-footer__meta">
      <a href="mailto:isaure-lohest@gmail.com">isaure-lohest@gmail.com</a>
      <span>&copy; {currentYear}</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    z-index: 2;
    margin-top: clamp(2rem, 4vw, 3.5rem);
    width: 100%;
    padding-bottom: calc(clamp(1.25rem, 2.4vw, 2rem) + env(safe-area-inset-bottom));
    background: var(--surface-base);
    color: var(--text-primary);
  }

  :global(html.home-palette-sun) .site-footer {
    background: var(--surface-base);
  }

  .site-footer--home {
    margin-top: clamp(1.5rem, 3vw, 2.75rem);
  }

  .site-footer__cta-bar {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: clamp(1rem, 3vw, 2rem);
    align-items: center;
    width: 100%;
    padding: clamp(1.4rem, 3vw, 2.3rem) clamp(1rem, 4vw, 2.5rem);
  }

  .site-footer__cta-title {
    margin: 0;
    font-size: clamp(2rem, 4.4vw, 4rem);
    line-height: 0.92;
    text-transform: uppercase;
  }

  /* Palette par défaut (bleue) : on laisse le comportement de base de
     .portfolio-pill-link (outline → hover interactive-primary), identique au
     bouton « Get in touch » de l'accueil. La palette sun garde ses overrides. */
  .site-footer__cta-link {
    font-size: clamp(0.9rem, 1vw, 1rem);
  }

  .site-footer__inner {
    display: grid;
    grid-template-columns: minmax(15rem, 1fr) minmax(13rem, auto);
    gap: clamp(1.25rem, 4vw, 4rem);
    align-items: end;
    width: 100%;
    padding: clamp(1.25rem, 2.4vw, 2rem) clamp(1rem, 4vw, 2.5rem) 0;
  }

  .site-footer__brand,
  .site-footer__meta {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .site-footer__name {
    width: fit-content;
    color: inherit;
    font-size: clamp(1.55rem, 2.6vw, 2.6rem);
    line-height: 0.95;
    text-decoration: none;
    text-transform: uppercase;
  }

  .site-footer__line {
    margin: 0;
    max-width: 31rem;
    color: color-mix(in srgb, var(--text-primary) 72%, transparent);
    font-size: clamp(0.86rem, 1vw, 0.98rem);
    line-height: 1.45;
  }

  .site-footer__location {
    margin: 0;
    color: color-mix(in srgb, var(--text-primary) 58%, transparent);
    font-size: clamp(0.8rem, 0.92vw, 0.9rem);
    line-height: 1.45;
  }

  .site-footer__meta {
    align-items: flex-end;
    color: color-mix(in srgb, var(--text-primary) 72%, transparent);
    font-size: clamp(0.82rem, 0.95vw, 0.94rem);
    line-height: 1.35;
    text-align: right;
  }

  .site-footer a {
    color: inherit;
    text-underline-offset: 0.25em;
    text-decoration-thickness: 1px;
    transition:
      color 0.2s ease,
      opacity 0.2s ease;
  }

  .site-footer a:hover,
  .site-footer a:focus-visible {
    color: var(--surface-accent);
  }

  .site-footer a:focus-visible {
    outline: 1px solid currentColor;
    outline-offset: 0.25rem;
  }

  :global(html.home-palette-sun) .site-footer .site-footer__cta-link {
    background: #ff572a;
    border-color: #ff572a;
    color: #ffffff;
  }

  :global(html.home-palette-sun) .site-footer .site-footer__cta-link:hover,
  :global(html.home-palette-sun) .site-footer .site-footer__cta-link:focus-visible {
    background: #343232;
    border-color: #343232;
    color: #fffcf0;
  }

  /* Palette jaune : hover rouge sur les liens du footer (nom + email). */
  :global(html.home-palette-sun) .site-footer__name:hover,
  :global(html.home-palette-sun) .site-footer__name:focus-visible,
  :global(html.home-palette-sun) .site-footer__meta a:hover,
  :global(html.home-palette-sun) .site-footer__meta a:focus-visible {
    color: #e63329;
  }

  @media (max-width: 628px) {
    .site-footer {
      padding-bottom: calc(1.35rem + env(safe-area-inset-bottom));
    }

    .site-footer__cta-bar {
      grid-template-columns: 1fr;
      gap: 1rem;
      align-items: flex-start;
      padding-block: 1.45rem;
    }

    .site-footer__cta-link {
      width: 100%;
      min-height: 3.25rem;
    }

    .site-footer__inner {
      grid-template-columns: 1fr;
      gap: 1.1rem;
      align-items: flex-start;
    }

    .site-footer__meta {
      align-items: flex-start;
      text-align: left;
    }
  }
</style>
