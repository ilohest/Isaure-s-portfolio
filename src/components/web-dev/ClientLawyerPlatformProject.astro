---
import ResponsiveImage from '../media/ResponsiveImage.astro';

import type { ImageMetadata } from 'astro';

const images = import.meta.glob<ImageMetadata>(
  '/src/assets/media-src/projects/web-dev/client-lawyer-platform/*.png',
  { eager: true, import: 'default' },
);
const pic = (base: string): ImageMetadata =>
  images[`/src/assets/media-src/projects/web-dev/client-lawyer-platform/${base}.png`];

const order = [1, 11, 3, 4, 5, 6, 7, 10];
const screens = order.map((n) => {
  const num = String(n).padStart(2, '0');
  return { base: `client-lawyer-platform-${num}`, alt: `Client-Lawyer Platform screen ${num}` };
});

const features = [
  {
    title: 'Client portal',
    text: 'Clients can submit legal requests, describe cases, and schedule initial consultations.',
  },
  {
    title: 'Lawyer dashboard',
    text: 'Professionals can manage cases, track progress, handle documents, and oversee payments.',
  },
  {
    title: 'Case lifecycle',
    text: 'Real-time status updates give every matter a clear, structured progression.',
  },
  {
    title: 'Secure documents',
    text: 'Sensitive files can be uploaded, stored, and organized in a protected environment.',
  },
  {
    title: 'Legal aid simulator',
    text: 'Eligibility checks adapt to dynamic requirements and validation rules.',
  },
  {
    title: 'Appointments',
    text: 'Scheduling is supported by intelligent availability management.',
  },
  {
    title: 'Notifications',
    text: 'Integrated updates keep clients and lawyers informed at each step.',
  },
];

const tags = ['Custom platform', 'Legal tech', 'Client portal'];
---

<section class="clp-project relative mx-auto px-4 py-4">
  <div class="clp-layout">
    <aside class="clp-sticky">
      <div class="clp-card-inner flex flex-col gap-4">
        <h1 class="project-title-reveal clp-title font-display m-0 uppercase">
          <span class="project-title-reveal__inner">Client-Lawyer Platform</span>
        </h1>
        <ul class="clp-tags" aria-label="Project tags">
          {tags.map((tag) => <li>{tag}</li>)}
        </ul>

        <div class="clp-copy">
          <p>
            This project is a custom-built platform designed to streamline the management of legal
            cases and client interactions for law professionals.
          </p>
          <p>
            The goal was to create a secure, intuitive environment that simplifies complex workflows
            while improving communication between clients and lawyers.
          </p>
        </div>

        <p class="clp-copy">
          The platform is built with a strong focus on data security, clarity of information, and
          efficiency, turning legal processes into a more accessible and structured experience for both
          clients and professionals.
        </p>
      </div>
    </aside>

    <div class="project-screens">
      <section class="clp-feature-panel" aria-labelledby="clp-features-title">
        <h2 id="clp-features-title" class="clp-section-title tracking-wide uppercase">
          Key features
        </h2>
        <hr class="clp-feature-rule" />
        <div class="clp-feature-list">
          {
            features.map((feature) => (
              <article class="clp-feature-item">
                <h3>{feature.title}</h3>
                <p>{feature.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      {
        screens.map((s) => (
          <ResponsiveImage
            src={pic(s.base)}
            alt={s.alt}
            sizes="(min-width: 1280px) 1040px, (min-width: 970px) 64vw, 100vw"
            loading="lazy"
            imgClass="project-screen"
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  .clp-project {
    width: min(100%, 1680px);
    max-width: min(100%, 1680px);
  }

  :global(.project-detail-page) > .clp-project {
    max-width: min(100%, 1680px);
  }

  .clp-layout {
    display: grid;
    grid-template-columns: minmax(18rem, 0.72fr) minmax(0, 1.58fr);
    gap: clamp(2rem, 4vw, 5rem);
    align-items: start;
  }

  .clp-sticky {
    position: sticky;
    top: clamp(1rem, 3vw, 2.5rem);
    min-width: 0;
  }

  .clp-card-inner {
    gap: clamp(0.95rem, 1.4vw, 1.25rem);
    padding: clamp(0.35rem, 1.2vw, 1rem) 0;
  }

  @media (min-width: 768px) {
    .clp-card-inner {
      padding-right: clamp(0.5rem, 1.5vw, 1.5rem);
    }
  }

  .clp-title {
    max-width: 12.5ch;
    color: var(--text-primary);
    font-size: clamp(2.4rem, 5.4vw, 5.8rem);
    line-height: 0.94;
    letter-spacing: 0.02em;
  }

  .clp-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .clp-tags li {
    border: 1px solid currentColor;
    border-radius: 999px;
    padding: 0.42rem 0.7rem;
    font-family: var(--font-family-display);
    font-size: 0.78rem;
    line-height: 1;
    text-transform: uppercase;
    color: var(--text-primary);
  }

  .clp-section-title {
    margin: 0;
    color: var(--text-primary);
    font-family: var(--font-family-display);
    font-size: clamp(1.1rem, 1.9vw, 1.7rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: 0.04em;
  }

  .clp-copy {
    font-family: 'Red Hat Text', sans-serif;
    font-weight: 300;
    color: var(--text-secondary);
  }

  .clp-copy,
  .clp-copy p {
    font-size: clamp(0.95rem, 1vw, 1.05rem);
    line-height: 1.56;
  }

  .clp-copy p + p {
    margin-top: 1rem;
  }

  .clp-feature-list {
    column-count: 2;
    column-gap: clamp(1.5rem, 4vw, 3.5rem);
  }

  .clp-feature-panel {
    padding: clamp(1.4rem, 2.8vw, 2.4rem);
    background: var(--palette-white);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
  }

  .clp-feature-rule {
    width: 100%;
    height: 0;
    margin: clamp(0.8rem, 1.6vw, 1.2rem) 0 clamp(1.2rem, 2.6vw, 2rem);
    border: 0;
    border-top: 1px solid color-mix(in srgb, var(--text-primary) 26%, transparent);
  }

  .clp-feature-item {
    break-inside: avoid;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    margin: 0 0 clamp(1.15rem, 2vw, 1.75rem);
    padding: 0;
  }

  .clp-feature-item h3 {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: 0;
    color: var(--text-primary);
    font-size: clamp(0.95rem, 1vw, 1.05rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: 0.02em;
    text-transform: none;
  }

  .clp-feature-item h3::after {
    content: '';
    display: block;
    width: 100%;
    height: 1px;
    background: color-mix(in srgb, var(--text-primary) 35%, transparent);
  }

  .clp-feature-item p {
    margin: 0;
    color: var(--text-secondary);
    font-family: 'Red Hat Text', sans-serif;
    font-size: clamp(0.92rem, 0.95vw, 1rem);
    font-weight: 300;
    line-height: 1.6;
  }

  .project-screens {
    display: grid;
    gap: clamp(2rem, 4.5vw, 4.25rem);
    min-width: 0;
  }

  .project-screens :global(.project-screen) {
    display: block;
    width: 100%;
    height: auto;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
  }

  @media (max-width: 1100px) {
    .clp-layout {
      grid-template-columns: minmax(17rem, 0.8fr) minmax(0, 1.2fr);
      gap: clamp(1.5rem, 3vw, 3rem);
    }

    .clp-title {
      font-size: clamp(2.25rem, 5vw, 4.6rem);
    }
  }

  @media (max-width: 860px) {
    .clp-layout {
      grid-template-columns: 1fr;
    }

    .clp-sticky {
      position: static;
    }

    .clp-card-inner {
      padding-right: 0;
    }

    .clp-title {
      max-width: 14ch;
      font-size: clamp(2.6rem, 13vw, 4.6rem);
    }

    .clp-feature-list {
      column-count: 1;
    }
  }

  @media (max-width: 560px) {
    .clp-project {
      padding-inline: 1rem;
    }
    .clp-feature-panel {
      padding: 1.25rem;
    }
  }

</style>
