---
const M = '/assets/media/projects/web-dev/private-events-dashboard';
const H = `${M}/highlights`;

// Hero (largeur principale, comme Averys).
const hero = {
  src: `${M}/invitation-site/bodanm-desktop1-960.avif`,
  alt: 'Wedding invitation website — desktop',
};

// Mockups du site d'invitation (groupe média centré).
const mockups = [
  { src: `${M}/invitation-site/bodanm-desktop6-960.avif`, alt: 'Wedding website — desktop view' },
  { src: `${M}/invitation-site/bodanm-mockup1-960.avif`, alt: 'Wedding website — phone mockup' },
];

const projectParagraphs = [
  "I designed and built an elegant, private wedding invitation website showcasing hand‑drawn illustrations, with subtle animations, all key event details, and a dedicated RSVP experience for guests to confirm attendance, plus‑ones, dietary needs, and notes. To protect guests' privacy, access is secured with a shared password.",
  'Behind the scenes, the back office is a full operations dashboard built to run the wedding end‑to‑end. It centralizes guest responses and dietary requirements, and provides tools to plan seating arrangements and generate printable exports for vendors and on‑site coordination. Organizers can manage a structured timeline/agenda, track budget items, curate a shared playlist, and publish updates through a lightweight blog. The dashboard also includes email tooling, role‑based access, and an AI assistant, with a super‑admin area to manage users, permissions, and invitation links.',
];

// Cartes image du bento (la 1re carte est la vidéo, gérée à part).
const features: { img: string; alt: string; title: string; text: string }[] = [
  { img: `${H}/admin-dashboard-960.avif`, alt: 'Admin dashboard overview', title: 'Dashboard & Metrics', text: 'Track RSVPs, attendance totals, and key planning metrics at a glance — so you can spot changes quickly and stay on top of what matters most.' },
  { img: `${H}/admin-rsvp-960.avif`, alt: 'RSVP management screen', title: 'RSVP Management', text: 'Review guest responses, plus‑ones, messages, statistics — without chasing spreadsheets.' },
  { img: `${H}/admin-diets-960.avif`, alt: 'Dietary requirements management', title: 'Dietary Requirements', text: 'Collect allergies and preferences, then export clean summaries for vendors.' },
  { img: `${H}/admin-seating-960.avif`, alt: 'Seating plan editor', title: 'Seating Plan', text: 'Build table assignments and generate print‑ready seating outputs.' },
  { img: `${H}/admin-playlist-960.avif`, alt: 'Playlist management', title: 'Playlist Curation', text: 'Gather song requests and curate the soundtrack in one place.' },
  { img: `${H}/admin-blog-960.avif`, alt: 'Blog administration', title: 'Blog / Updates', text: 'Publish guest‑facing updates through a lightweight blog feed.' },
  { img: `${H}/admin-email-960.avif`, alt: 'Email tooling screen', title: 'Email Center', text: 'Send targeted messages and review delivery history when needed.' },
  { img: `${H}/admin-weddingplanner-960.avif`, alt: 'Wedding planner workspace', title: 'Wedding Planner', text: 'Turn ideas into actionable tasks with built‑in assistance to speed up planning.' },
  { img: `${H}/admin-rsvp-form-960.avif`, alt: 'RSVP form preview', title: 'Guest RSVP Experience', text: 'A guided and personalized RSVP flow for guests (attendance, plus‑ones, dietary needs, notes).' },
  { img: `${H}/admin-budget-960.avif`, alt: 'Budget tracking dashboard', title: 'Budget Tracking', text: 'Track expenses, categories, and payments to keep the budget under control.' },
  { img: `${H}/admin-agenda-960.avif`, alt: 'Agenda and timeline editor', title: 'Agenda / Timeline', text: 'Organize the wedding day step by step, define schedules, assign responsibilities, and visualize the entire planning at a glance.' },
];

const ctas = [
  { base: `${M}/cta/cta-couple`, alt: 'Wedding editorial portrait', q: 'Are you planning a wedding or event and want a digital invitation that actually saves you time?', t: 'Get a bespoke illustrated invitation site plus a private operations dashboard to handle RSVPs, seating, emails, and planning — smoothly and securely.', label: 'Request a demo', icon: 'pi-envelope' },
  { base: `${M}/cta/cta-agency`, alt: 'Ocean spray with rainbow', q: 'Are you a design studio or stationery brand looking to offer more than printed invitations?', t: 'Bring your custom illustrations into my platform and deliver a premium bundle: a stunning invitation website paired with a full guest‑management dashboard.', label: "Let’s talk partnership", icon: 'pi-send' },
];

const dir = (i: number) => (i % 2 === 0 ? 'slide-from-left' : 'slide-from-right');
---

<section class="ed-project relative flex flex-col">
  <div class="ed-layout">
    <aside class="ed-sticky">
      <header class="ed-headline">
        <h1 class="project-title-reveal font-display m-0 uppercase">
          <span class="project-title-reveal__inner">
            Private event operations dashboard
            <span class="ed-title-sub">Wedding Edition</span>
          </span>
        </h1>
        <ul class="ed-tags" aria-label="Project tags">
          <li>Product design</li>
          <li>Full-stack dev</li>
          <li>UX/UI</li>
        </ul>
        <div class="ed-meta" aria-label="Project details">
          <p><i>Client: </i>Natalia &amp; Mauricio</p>
          <p><i>Sector: </i>Weddings &amp; events</p>
          <p><i>Format: </i>Invitation site + operations dashboard</p>
          <p><i>URL: </i><a href="https://www.natalia-y-mauricio.com/" target="_blank" rel="noopener noreferrer">natalia-y-mauricio.com</a></p>
          <p><i>Credits: </i>Illustrations by La Invitación de Liana</p>
        </div>
      </header>
    </aside>

    <div class="ed-main-flow">
      <figure class="ed-hero">
        <img src={hero.src} alt={hero.alt} loading="eager" fetchpriority="high" decoding="async" />
      </figure>

      <div class="ed-study-card masonry-reveal">
        <article class="ed-block">
          <h2 class="ed-block__title">Project</h2>
          <hr class="ed-block__rule" />
          <div class="ed-block__body">
            {projectParagraphs.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </article>

        <article class="ed-block">
          <h2 class="ed-block__title">Responsibilities</h2>
          <hr class="ed-block__rule" />
          <div class="ed-block__body">
            <p>
              Product design &amp; technical architecture - Front-end development - Back-end/API
              development - Database &amp; authentication - Custom illustration integration - UI/UX
              - Security &amp; access control - Deployment &amp; server setup - Launch &amp;
              post-launch support
            </p>
          </div>
        </article>
      </div>

      <div class="ed-mockups">
        {
          mockups.map((m) => (
            <figure class="ed-mockup masonry-reveal">
              <img src={m.src} alt={m.alt} loading="lazy" decoding="async" />
            </figure>
          ))
        }
      </div>

      <header class="ed-section-head">
        <h2>The platform highlights</h2>
        <p>A quick tour of the tools used to run a private wedding end‑to‑end.</p>
      </header>

      <div class="bento-grid" data-slide-enable>
        <article class={`feature-card js-slide-item ${dir(0)}`}>
          <div class="slide-content">
            <video class="feature-media" src="/media/videos/private-events-dashboard-home.mp4" playsinline autoplay loop muted preload="metadata"></video>
            <div class="feature-copy">
              <h3>Digital invitation experience</h3>
              <p>An elegant private invitation website designed around bespoke, hand‑drawn illustrations to match each couple's world.</p>
            </div>
          </div>
        </article>

        {features.map((f, i) => (
          <article class={`feature-card js-slide-item ${dir(i + 1)}`}>
            <div class="slide-content">
              <img class="feature-media" src={f.img} alt={f.alt} loading="lazy" decoding="async" />
              <div class="feature-copy">
                <h3>{f.title}</h3>
                <p>{f.text}</p>
              </div>
            </div>
          </article>
        ))}

        {ctas.map((c, i) => (
          <article class={`cta-card feature-card js-slide-item ${dir(features.length + 1 + i)}`}>
            <div class="slide-content">
              <picture>
                <source srcset={`${c.base}-960.avif`} type="image/avif" />
                <source srcset={`${c.base}-960.webp`} type="image/webp" />
                <img class="cta-media" src={`${c.base}-960.jpg`} alt={c.alt} loading="lazy" decoding="async" />
              </picture>
              <div class="cta-body">
                <h3 class="cta-question font-display text-xl uppercase">{c.q}</h3>
                <p class="cta-text">{c.t}</p>
                <a href="/contact" class="cta-button"><span class={`pi ${c.icon}`} aria-hidden="true"></span>{c.label}</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import '../../scripts/slide-in.ts';
  import '../../scripts/masonry-reveal.ts';
</script>

<style>
  /* Coquille reprise de la page Averys : colonne gauche fixe + flux à droite. */
  :global(.project-detail-page) > .ed-project {
    width: 100%;
    max-width: min(100%, 1680px);
    margin-inline: auto;
    padding-inline: 20px;
    padding-block: clamp(0.5rem, 2vw, 1.5rem);
    gap: clamp(2.5rem, 7vw, 5.5rem);
  }

  .ed-layout {
    display: grid;
    grid-template-columns: minmax(18rem, 0.72fr) minmax(0, 1.58fr);
    gap: clamp(2rem, 4vw, 5rem);
    align-items: start;
  }

  .ed-sticky {
    position: sticky;
    top: clamp(1rem, 3vw, 2.5rem);
    min-width: 0;
  }

  .ed-headline {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .ed-headline h1 {
    color: var(--text-primary);
    font-size: clamp(2rem, 3.4vw, 3.4rem);
    line-height: 0.95;
  }

  .ed-title-sub {
    display: block;
    margin-top: 0.35em;
    font-size: clamp(0.95rem, 1.5vw, 1.4rem);
    letter-spacing: 0.06em;
  }

  .ed-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .ed-tags li {
    border: 1px solid currentColor;
    border-radius: 999px;
    padding: 0.42rem 0.7rem;
    color: var(--text-primary);
    font-family: var(--font-family-display);
    font-size: 0.78rem;
    line-height: 1;
    text-transform: uppercase;
  }

  .ed-meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    max-width: 34ch;
    color: var(--text-secondary);
    font-family: var(--font-family-body);
    font-size: 0.95rem;
    font-weight: 300;
    line-height: 1.45;
  }

  .ed-meta p {
    margin: 0;
  }

  .ed-meta i {
    color: var(--text-primary);
    font-style: italic;
    text-transform: uppercase;
  }

  .ed-meta a {
    color: inherit;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.16em;
  }

  .ed-main-flow {
    --ed-flow-gap: clamp(2.4rem, 6vw, 4.5rem);
    --ed-soft-shadow:
      0 18px 42px rgba(35, 35, 35, 0.14),
      0 4px 12px rgba(35, 35, 35, 0.08);

    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: var(--ed-flow-gap);
  }

  .ed-hero {
    overflow: hidden;
    width: min(100%, 580px);
    margin: 0 auto;
    border-radius: var(--project-card-radius);
  }

  .ed-hero img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Blocs texte façon Averys : titre + filet + corps poussé à droite. */
  .ed-study-card {
    display: flex;
    width: 100%;
    flex-direction: column;
    gap: clamp(2.4rem, 6vw, 4.5rem);
    padding: clamp(1.4rem, 2.8vw, 2.4rem);
    background: var(--palette-white);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
  }

  .ed-block__title {
    margin: 0;
    color: var(--text-primary);
    font-family: var(--font-family-display);
    font-size: clamp(1.1rem, 1.9vw, 1.7rem);
    font-weight: 400;
    letter-spacing: 0.04em;
    line-height: 1.05;
    text-transform: uppercase;
  }

  .ed-block__rule {
    width: 100%;
    height: 0;
    margin: clamp(0.8rem, 1.6vw, 1.2rem) 0 clamp(1.2rem, 2.6vw, 2rem);
    border: 0;
    border-top: 1px solid color-mix(in srgb, var(--text-primary) 26%, transparent);
  }

  .ed-block__body {
    display: flex;
    width: min(100%, 62ch);
    margin-left: auto;
    flex-direction: column;
    gap: 1rem;
    color: var(--text-secondary);
    font-family: var(--font-family-body);
    font-weight: 300;
  }

  .ed-block__body p {
    margin: 0;
    font-size: 1rem;
    line-height: 1.65;
  }

  /* Mockups du site d'invitation (groupe centré, type "compact" Averys). */
  .ed-mockups {
    display: flex;
    flex-direction: column;
    gap: clamp(1.4rem, 3vw, 2.2rem);
    width: min(100%, 680px);
    margin-inline: auto;
  }

  .ed-mockup {
    margin: 0;
    overflow: hidden;
    border-radius: var(--project-card-radius);
  }

  .ed-mockup img {
    display: block;
    width: 100%;
    height: auto;
  }

  .ed-section-head {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-width: 60ch;
  }

  .ed-section-head h2 {
    margin: 0;
    color: var(--text-primary);
    font-family: var(--font-family-display);
    font-size: clamp(1.6rem, 3vw, 2.6rem);
    font-weight: 400;
    line-height: 1;
    text-transform: uppercase;
  }

  .ed-section-head p {
    margin: 0;
    color: var(--text-secondary);
    font-family: 'Red Hat Text', sans-serif;
    font-weight: 300;
  }

  /* ── Bento highlights (conservé) ───────────────────────────────── */
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    justify-content: center;
    justify-items: stretch;
  }
  @media (min-width: 640px) {
    .bento-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      align-items: start;
    }
  }
  .feature-card {
    width: 100%;
  }

  .enable-slide .slide-content {
    opacity: 0;
    transition:
      transform 720ms cubic-bezier(0.2, 0.9, 0.2, 1),
      opacity 520ms ease-out;
    will-change: transform, opacity;
  }
  .enable-slide .slide-from-left .slide-content {
    transform: translateX(-80vw);
  }
  .enable-slide .slide-from-right .slide-content {
    transform: translateX(80vw);
  }
  .enable-slide .js-slide-item.is-in .slide-content {
    transform: translateX(0);
    opacity: 1;
  }

  /* Cartes highlights : fond blanc + ombre, comme .ed-study-card. */
  .feature-card:not(.cta-card) .slide-content {
    overflow: hidden;
    border-radius: var(--image-radius);
    background: var(--palette-white);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
  }

  .feature-media {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }
  .feature-copy {
    color: var(--text-primary);
    padding: 22px 22px 24px;
  }
  .feature-copy h3 {
    margin: 0;
    font-family: var(--font-family-display);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 1.3rem;
    color: var(--text-primary);
  }
  .feature-copy p {
    margin: 14px 0 0;
    font-family: 'Red Hat Text', sans-serif;
    font-weight: 300;
    color: var(--text-primary);
  }

  /* CTA cards */
  .cta-card .slide-content {
    border: 1px solid var(--text-primary);
    border-radius: var(--image-radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    background: var(--surface-muted);
  }
  .cta-media {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }
  .cta-card picture {
    display: block;
  }
  .cta-body {
    background: var(--surface-accent);
    color: var(--text-inverse);
    padding: 26px 26px 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .cta-question {
    margin: 0;
    line-height: 1.15;
    color: var(--text-inverse);
  }
  .cta-text {
    margin: 0;
    opacity: 0.92;
    color: var(--text-inverse);
    font-family: 'Red Hat Text', sans-serif;
    font-weight: 300;
  }
  .cta-button {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #fff;
    border: 1px solid #fff;
    color: var(--surface-accent);
    border-radius: 6px;
    padding: 0.55rem 1.1rem;
    text-decoration: none;
    font-family: 'Synt Mono Regular', ui-monospace, monospace;
    font-size: 0.86rem;
    text-transform: uppercase;
    font-weight: 400;
    transition: background 0.2s ease;
  }
  .cta-button:hover {
    background: color-mix(in oklab, #fff, transparent 8%);
  }

  /* Palette jaune : fond des cards (surface-accent) jaune → texte foncé. */
  :global(html.home-palette-sun) .cta-body,
  :global(html.home-palette-sun) .cta-question,
  :global(html.home-palette-sun) .cta-text,
  :global(html.home-palette-sun) .cta-button {
    color: var(--text-primary);
  }

  @media (max-width: 960px) {
    .ed-layout {
      grid-template-columns: 1fr;
      gap: clamp(1.5rem, 5vw, 3rem);
    }

    .ed-sticky {
      position: static;
    }

    .ed-headline h1 {
      font-size: clamp(2rem, 9vw, 3rem);
    }

    .ed-meta,
    .ed-block__body {
      max-width: none;
      width: 100%;
      margin-left: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .js-slide-item .slide-content,
    .js-slide-item.is-in .slide-content {
      transition: none;
      transform: none;
      opacity: 1 !important;
    }
  }
</style>
