---
import ResponsiveImage from '../media/ResponsiveImage.astro';

import type { ImageMetadata } from 'astro';

const images = import.meta.glob<ImageMetadata>(
  '/src/assets/media-src/projects/web-dev/averys/*.png',
  { eager: true, import: 'default' },
);
const pic = (base: string): ImageMetadata =>
  images[`/src/assets/media-src/projects/web-dev/averys/${base}.png`];

type Item =
  | { type: 'image'; base: string; alt: string; href?: string }
  | { type: 'video'; src: string; alt: string }
  | { type: 'study'; variant: 'project' | 'motion' };

// L'image 1 est le hero (group-32). La galerie commence donc à l'image 2.
const items: Item[] = [
  { type: 'image', base: 'group-36', alt: 'A curated editorial homepage for Averys', href: 'https://averys.app' },
  { type: 'image', base: 'averys mockup2', alt: 'Averys desktop mockup 2' },
  { type: 'image', base: 'group-38', alt: 'Averys — editorial branding composition' },
  { type: 'image', base: 'group-35', alt: 'Averys — visual identity composition' },
  { type: 'image', base: 'logo2', alt: 'Averys logo exploration 2' },
  { type: 'study', variant: 'project' },
  { type: 'video', src: '/media/videos/averys-video2.mp4', alt: 'Averys motion sequence 2' },
  { type: 'study', variant: 'motion' },
  { type: 'video', src: '/media/videos/averys-video1.mp4', alt: 'Averys motion sequence 1' },
  { type: 'image', base: 'averys2', alt: 'Averys interface detail 2' },
  { type: 'video', src: '/media/videos/averys-video3.mp4', alt: 'Averys motion sequence 3' },
  { type: 'image', base: 'averys4', alt: 'Averys interface detail 4' },
  { type: 'video', src: '/media/videos/averys-video4.mp4', alt: 'Averys motion sequence 4' },
  { type: 'image', base: 'averys5', alt: 'Averys interface detail 5' },
  { type: 'video', src: '/media/videos/averys-video5.mp4', alt: 'Averys motion sequence 5' },
  { type: 'image', base: 'averys6', alt: 'Averys interface detail 6' },
  { type: 'video', src: '/media/videos/averys-video6.mp4', alt: 'Averys motion sequence 6' },
];

const ar = (item: Item): number => {
  if (item.type !== 'image') return 16 / 9;
  const p = pic(item.base);
  return p && p.height ? Math.max(p.width / p.height, 0.3) : 1;
};

const isCompactGalleryItem = (item: Item): boolean => item.type === 'image' && ar(item) < 1.31;

const projectParagraphs = [
  'For Averys, I designed and developed an editorial website with a refined and immersive visual language. The approach focused on creating a strong sense of atmosphere through warm tones, expressive typography, generous spacing, and a carefully paced layout.',
  'The website was conceived as a visual system for curated event experiences: polished enough to feel premium, but flexible enough to support changing content, invitations, and presentation moments.',
];

const interactionParagraphs = [
  'I paid particular attention to motion and interaction design, using subtle reveals, layered animations, and fluid transitions to give the site depth and rhythm.',
  'The logo and visual details were designed alongside the interface, helping shape a cohesive identity across the full digital experience.',
  'The result is a polished and distinctive website that feels both elegant and contemporary, with a strong emphasis on visual composition, movement, and front-end detail.',
];
---

<section class="averys-project relative flex flex-col">
  <div class="averys-layout">
    <aside class="averys-sticky">
      <header class="averys-headline">
        <h1 class="project-title-reveal font-display m-0 uppercase">
          <span class="project-title-reveal__inner">Averys</span>
        </h1>
        <ul class="averys-tags" aria-label="Project tags">
          <li>Web design</li>
          <li>Front-end</li>
          <li>Editorial identity</li>
        </ul>
        <div class="averys-meta" aria-label="Project details">
          <p><i>Client: </i>Averys</p>
          <p><i>Sector: </i>Curated events</p>
          <p><i>Format: </i>Logo & Editorial website</p>
          <p><i>URL: </i><a href="https://averys.app" target="_blank" rel="noopener noreferrer">averys.app</a></p>
        </div>
      </header>
    </aside>

    <div class="averys-main-flow">
      <figure class="averys-hero">
        <ResponsiveImage
          src={pic('group-32')}
          alt="Averys — editorial event branding cover"
          sizes="(min-width: 1280px) 64vw, (min-width: 970px) calc(100vw - 24rem), calc(100vw - 2rem)"
          loading="eager"
          fetchpriority="high"
          imgClass="averys-hero-img"
        />
      </figure>

      <section class="averys-gallery" aria-label="Averys project gallery">
        {
          items.map((item, index) => {
            if (item.type === 'study') {
              return (
                <div class="averys-study-card masonry-reveal">
                  {item.variant === 'project' ? (
                    <Fragment>
                      <article class="averys-block">
                        <h2 class="averys-block__title">Project</h2>
                        <hr class="averys-block__rule" />
                        <div class="averys-block__body">
                          {projectParagraphs.map((paragraph) => <p>{paragraph}</p>)}
                        </div>
                      </article>
                      <article class="averys-block">
                        <h2 class="averys-block__title">Responsibilities</h2>
                        <hr class="averys-block__rule" />
                        <div class="averys-block__body">
                          <p>Art direction - Logo design - Web design - UX/UI design - Front-end development - Animation design</p>
                        </div>
                      </article>
                    </Fragment>
                  ) : (
                    <article class="averys-block">
                      <h2 class="averys-block__title">Motion & identity</h2>
                      <hr class="averys-block__rule" />
                      <div class="averys-block__body">
                        {interactionParagraphs.map((paragraph) => <p>{paragraph}</p>)}
                      </div>
                    </article>
                  )}
                </div>
              );
            }

            const compact = isCompactGalleryItem(item);
            const mediaSizes = compact
              ? '(min-width: 1280px) 46vw, (min-width: 970px) 52vw, 86vw'
              : '(min-width: 1280px) 64vw, (min-width: 970px) calc(100vw - 24rem), calc(100vw - 2rem)';
            const imageLoading = index === 0 ? 'eager' : 'lazy';
            const imagePriority = index === 0 ? 'high' : 'auto';

            return (
              <article class={`averys-gallery-item masonry-reveal${compact ? ' is-compact' : ''}`}>
                {item.type === 'image' && item.href ? (
                  <a
                    class="averys-media-link"
                    href={item.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`${item.alt} — open averys.app`}
                  >
                    <ResponsiveImage
                      src={pic(item.base)}
                      alt={item.alt}
                      sizes={mediaSizes}
                      loading={imageLoading}
                      fetchpriority={imagePriority}
                      imgClass="averys-gallery-media"
                    />
                  </a>
                ) : item.type === 'image' ? (
                  <div class="averys-media-link">
                    <ResponsiveImage
                      src={pic(item.base)}
                      alt={item.alt}
                      sizes={mediaSizes}
                      loading={imageLoading}
                      fetchpriority={imagePriority}
                      imgClass="averys-gallery-media"
                    />
                  </div>
                ) : (
                  <div class="averys-media-link">
                    <video class="averys-gallery-media" src={item.src} aria-label={item.alt} autoplay loop muted playsinline preload="metadata" />
                  </div>
                )}
              </article>
            );
          })
        }
      </section>
    </div>
  </div>
</section>

<script>
  import '../../scripts/masonry-reveal.ts';
</script>

<style>
  :global(.project-detail-page) > .averys-project {
    width: 100%;
    max-width: min(100%, 1680px);
    margin-inline: auto;
    padding-inline: 20px;
    padding-block: clamp(0.5rem, 2vw, 1.5rem);
    gap: clamp(2.5rem, 7vw, 5.5rem);
  }

  .averys-layout {
    display: grid;
    grid-template-columns: minmax(18rem, 0.72fr) minmax(0, 1.58fr);
    gap: clamp(2rem, 4vw, 5rem);
    align-items: start;
  }

  .averys-sticky {
    position: sticky;
    top: clamp(1rem, 3vw, 2.5rem);
    min-width: 0;
  }

  .averys-headline {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .averys-headline h1 {
    max-width: 8ch;
    color: var(--text-primary);
    font-size: clamp(2.8rem, 6vw, 5.2rem);
    line-height: 0.92;
  }

  .averys-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .averys-tags li {
    border: 1px solid currentColor;
    border-radius: 999px;
    padding: 0.42rem 0.7rem;
    color: var(--text-primary);
    font-family: var(--font-family-display);
    font-size: 0.78rem;
    line-height: 1;
    text-transform: uppercase;
  }

  .averys-meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    max-width: 31ch;
    color: var(--text-secondary);
    font-family: var(--font-family-body);
    font-size: 0.95rem;
    font-weight: 300;
    line-height: 1.45;
  }

  .averys-meta p {
    margin: 0;
  }

  .averys-meta i {
    color: var(--text-primary);
    font-style: italic;
    text-transform: uppercase;
  }

  .averys-meta a {
    color: inherit;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.16em;
  }

  .averys-main-flow {
    --averys-flow-gap: clamp(2.4rem, 6vw, 4.5rem);
    --averys-soft-shadow:
      0 18px 42px rgba(35, 35, 35, 0.14),
      0 4px 12px rgba(35, 35, 35, 0.08);

    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: var(--averys-flow-gap);
  }

  .averys-hero {
    overflow: hidden;
    width: 100%;
    margin: 0;
    border-radius: var(--project-card-radius);
    background: #f7f2ed;
    box-shadow: var(--averys-soft-shadow);
  }

  .averys-hero a {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .averys-hero :global(.averys-hero-img) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0;
  }

  .averys-study-card {
    display: flex;
    width: 100%;
    flex-direction: column;
    gap: clamp(2.4rem, 6vw, 4.5rem);
    padding: clamp(1.4rem, 2.8vw, 2.4rem);
    margin-block: clamp(0.4rem, 1.6vw, 1.4rem);
    background: var(--palette-white);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
  }

  .averys-block__title {
    margin: 0;
    color: var(--text-primary);
    font-family: var(--font-family-display);
    font-size: clamp(1.1rem, 1.9vw, 1.7rem);
    font-weight: 400;
    letter-spacing: 0.04em;
    line-height: 1.05;
    text-transform: uppercase;
  }

  .averys-block__rule {
    width: 100%;
    height: 0;
    margin: clamp(0.8rem, 1.6vw, 1.2rem) 0 clamp(1.2rem, 2.6vw, 2rem);
    border: 0;
    border-top: 1px solid color-mix(in srgb, var(--text-primary) 26%, transparent);
  }

  .averys-block__body {
    display: flex;
    width: min(100%, 62ch);
    margin-left: auto;
    flex-direction: column;
    gap: 1rem;
    color: var(--text-secondary);
    font-family: var(--font-family-body);
    font-weight: 300;
  }

  .averys-block__body p {
    margin: 0;
    font-size: 1rem;
    line-height: 1.65;
  }

  .averys-gallery {
    display: flex;
    width: 100%;
    flex-direction: column;
    gap: clamp(1.4rem, 3vw, 2.2rem);
  }

  .averys-gallery-item {
    width: 100%;
  }

  .averys-gallery-item.is-compact {
    width: min(72%, 720px);
    margin-inline: auto;
  }

  .averys-media-link {
    display: block;
    overflow: hidden;
    text-decoration: none;
  }

  .averys-project :global(.averys-gallery-media) {
    width: 100%;
    display: block;
    border-radius: var(--project-card-radius);
    border: 1px solid var(--surface-muted);
    background: #f7f2ed;
    transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  @media (hover: hover) and (pointer: fine) {
    .averys-media-link[href]:hover :global(.averys-gallery-media),
    .averys-media-link[href]:focus-visible :global(.averys-gallery-media) {
      transform: scale(1.04);
    }
  }

  @media (max-width: 960px) {
    .averys-layout {
      grid-template-columns: 1fr;
      gap: clamp(1.5rem, 5vw, 3rem);
    }

    .averys-sticky {
      position: static;
    }

    .averys-headline h1 {
      max-width: none;
      font-size: clamp(2.7rem, 15vw, 4.8rem);
    }

    .averys-meta,
    .averys-block__body {
      max-width: none;
      width: 100%;
      margin-left: 0;
    }
  }

  @media (max-width: 628px) {
    .averys-gallery-item.is-compact {
      width: min(88%, 430px);
    }
  }
</style>
