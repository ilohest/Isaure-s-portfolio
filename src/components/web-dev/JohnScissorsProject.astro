---
const M = '/assets/media/projects/web-dev/john-scissors';
const APP = '/John-Scissors/index.html';
---

<section class="js-project relative container mx-auto flex flex-col gap-4 px-4 py-4">
  <div class="project-summary">
    <h2 class="project-title">John Scissors</h2>

    <div class="project-info">
      A single page demo website of a traditional barber. Know-how and expertise at customer service.
    </div>

    <div class="project-container">
      <div class="project-resp">
        <h2>Responsibilities</h2>
        <p>Web design, Front-end web application Development, Launch</p>
      </div>
      <div class="project-url">
        <h2>URL</h2>
        <a href={APP} target="_blank" rel="noopener noreferrer">isaure-lohest.com/achievements/john-scissors-project</a>
      </div>
    </div>
  </div>

  <div class="cards-container">
    <p class="responsive">Desktop vue of the website.</p>

    <div class="project-card project-card-video">
      <video class="video-projet" src="/media/videos/video-barbier.mp4" poster={`${M}/barber-temp-960.avif`} autoplay loop muted playsinline preload="auto"></video>
    </div>

    <div class="project-card project-card-desktop">
      <div class="image-container"><img src={`${M}/barber-desktop1-960.avif`} alt="John Scissors desktop view 1" loading="lazy" decoding="async" /></div>
      <div class="image-container"><img src={`${M}/barber-desktop2-960.avif`} alt="John Scissors desktop view 2" loading="lazy" decoding="async" /></div>
    </div>

    <p class="responsive">The website is completely adaptable, providing an impressive display on mobile devices as well.</p>

    <div class="project-card carte">
      <div class="image12">
        <div class="photo"><img src={`${M}/barber-phone1-960.avif`} alt="John Scissors mobile view" loading="lazy" decoding="async" /></div>
        <div class="photo"><img src={`${M}/barber-phone2-960.avif`} alt="John Scissors mobile view" loading="lazy" decoding="async" /></div>
      </div>
      <div class="image34">
        <div class="photo"><img src={`${M}/barber-phone3-960.avif`} alt="John Scissors mobile view" loading="lazy" decoding="async" /></div>
        <div class="photo"><img src={`${M}/barber-phone4-960.avif`} alt="John Scissors mobile view" loading="lazy" decoding="async" /></div>
      </div>
    </div>

    <p class="responsive">Web developement using HTML5, CSS3, and JavaScript in Visual Studio Code.</p>

    <div class="project-card project-card-dev">
      <div class="image-container-dev"><img src={`${M}/barber-web-dev-960.avif`} alt="John Scissors code editor screen" loading="lazy" decoding="async" /></div>
    </div>

    <div class="check">
      <a href={APP} class="button" target="_blank" rel="noopener noreferrer">Check it out</a>
    </div>
  </div>
</section>

<style>
  .project-summary {
    border-radius: var(--project-card-radius);
    padding: clamp(1.25rem, 4vw, 40px);
    background: var(--surface-muted);
    color: var(--text-secondary);
  }
  .project-title {
    font-family: var(--font-family-display);
    font-size: clamp(2rem, 4vw, 34px);
    text-transform: uppercase;
    color: var(--text-primary);
    margin-bottom: 20px;
  }
  .project-info {
    font-size: var(--fs-18);
    margin: 20px 0 30px 0;
  }
  .project-container {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    font-size: var(--fs-30);
  }
  .project-summary h2 {
    color: var(--text-secondary);
    text-transform: uppercase;
    font-size: var(--fs-18);
    letter-spacing: 0.05em;
    font-family: var(--font-family-display);
    line-height: 1.9167rem;
    font-weight: 400;
    margin-bottom: 20px;
  }
  .project-resp {
    width: 60%;
    font-size: var(--fs-20);
  }
  .project-url {
    width: 40%;
    font-size: var(--fs-20);
    margin-left: 80px;
  }
  .project-url a {
    text-decoration: none;
    color: inherit;
  }

  .cards-container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .project-card {
    background-color: var(--surface-muted);
    overflow: hidden;
    padding: 15px;
    border-radius: var(--project-card-radius);
  }
  .project-card-video {
    height: 650px;
  }
  .video-projet {
    overflow: hidden;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    border-radius: var(--project-card-radius);
    border: 2px var(--surface-muted) solid;
  }
  .project-card-desktop {
    height: 444px;
    display: flex;
    pointer-events: none;
  }
  .image-container {
    width: 50%;
    overflow: hidden;
  }
  .image-container:nth-child(1) {
    padding-right: 15px;
  }
  .image-container img {
    width: 100%;
    display: block;
    border-radius: var(--project-card-radius);
    height: 414px;
    object-position: top;
    object-fit: cover;
  }
  .responsive {
    color: var(--interactive-primary);
    margin: 20px;
    width: 100%;
  }
  .project-card.carte {
    display: flex;
    height: 790px;
    padding: 15px;
    pointer-events: none;
  }
  .image12 {
    padding-right: 15px;
  }
  .image12,
  .image34 {
    display: flex;
    gap: 15px;
    width: 50%;
  }
  .image12 .photo,
  .image34 .photo {
    flex: 1;
    overflow: hidden;
  }
  .image12 .photo img,
  .image34 .photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .photo img {
    border-radius: var(--project-card-radius);
  }
  .project-card-dev {
    height: 700px;
    padding: 15px;
    display: flex;
  }
  .image-container-dev {
    height: 100%;
    overflow: hidden;
    border-radius: var(--project-card-radius);
  }
  .image-container-dev img {
    width: 100%;
  }
  .check {
    display: flex;
    justify-content: center;
  }
  .button {
    text-align: center;
    text-decoration: none;
    margin: 0 auto 80px;
    display: block;
    background-color: var(--accent-positive);
    color: var(--interactive-primary);
    padding: 8px 20px;
    border: 2px solid;
    border-radius: var(--project-card-radius);
    cursor: pointer;
    text-transform: uppercase;
    font-size: var(--fs-18);
    letter-spacing: 0.05em;
    font-family: var(--font-family-display);
    line-height: 1.9167rem;
    font-weight: 400;
  }
  .button:hover {
    background: var(--accent-positive-hover);
  }

  @media screen and (max-width: 970px) {
    .project-card-dev {
      height: 388px;
    }
    .project-card-desktop {
      min-height: 1000px;
      height: auto;
      flex-direction: column;
      gap: 15px;
    }
    .image-container {
      width: 100%;
      overflow: hidden;
      padding: 0 !important;
    }
    .image-container img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .project-card.carte {
      height: 1630px;
      flex-direction: column;
    }
    .image12,
    .image34 {
      height: 50%;
      width: 100%;
      flex-direction: column;
    }
    .image12 .photo img,
    .image34 .photo img {
      width: 100%;
      height: 100%;
    }
    .project-container {
      flex-direction: column;
      gap: 1.5rem;
    }
    .project-resp,
    .project-url {
      width: 100%;
      margin-left: 0;
    }
  }
</style>
