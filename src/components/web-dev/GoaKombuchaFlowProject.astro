---
// Goa n'a pas de sources dans media-src/ : webp statiques déjà dans public/.
const MEDIA = '/assets/media/projects/web-dev/goa-kombucha-flow';

const screens: [string, string][] = [
  ['goa-kombucha-flow-01-dashboard.webp', 'Goa Kombucha lot history'],
  ['goa-kombucha-flow-03-production-detail.webp', 'Goa Kombucha stock item settings'],
  ['goa-kombucha-flow-04-lot-history.webp', 'Goa Kombucha stock overview'],
  ['goa-kombucha-flow-05-lot-export.webp', 'Goa Kombucha completed lot details'],
  ['goa-kombucha-flow-06-deliveries.webp', 'Goa Kombucha deliveries screen'],
  ['goa-kombucha-flow-07-stock.webp', 'Goa Kombucha production details'],
  ['goa-kombucha-flow-08-stock-item.webp', 'Goa Kombucha mobile dashboard'],
  ['goa-kombucha-flow-09-pdf.webp', 'Goa Kombucha recipe library'],
  ['goa-kombucha-flow-02-recipes.webp', 'Goa Kombucha PDF recipe export'],
];

const overviewParagraphs = [
  "Goa Kombucha Flow is a mobile-first production platform created to migrate the client's operational spreadsheets into a practical web app that can be used directly from a phone in the production area.",
  'The goal was to make recipe management, batch tracking, stock control, and production decisions easier to handle on the floor: fewer scattered files, less back-and-forth, and a clearer workflow for preparing, following, duplicating, and documenting batches.',
  'The app centralizes product formulas, active productions, lot history, ingredient stock, deliveries, and PDF exports in one interface designed around the constraints of real production use: quick checks, readable screens, and reliable access from a mobile device.',
  'Because the platform handles confidential recipes, quantities, prices, and supplier information, the case-study screens shown here are intentionally anonymized while preserving the structure and workflow of the interface.',
];

const features = [
  'Mobile production dashboard with active batches, status steps, and stock alerts',
  'Recipe library with product versions, ingredient logic, and batch calculations',
  'Lot creation, duplication, history, notes, and production PDF export',
  'Inventory views for ingredients, critical thresholds, deliveries, and order needs',
  'Operational tracking for measurements, starter, water, filtration, and bottling',
];
---

<section class="goa-project relative flex flex-col">
  <div class="goa-layout">
    <aside class="goa-sticky">
      <header class="goa-headline">
        <h1 class="project-title-reveal font-display m-0 uppercase">
          <span class="project-title-reveal__inner">Goa Kombucha Flow</span>
        </h1>
        <ul class="goa-tags" aria-label="Project tags">
          <li>Custom platform</li>
          <li>Production workflow</li>
          <li>Mobile-first</li>
        </ul>
        <div class="goa-meta" aria-label="Project details">
          <p><i>Client: </i>Goa Kombucha</p>
          <p><i>Sector: </i>Food production</p>
          <p><i>Format: </i>Operational web app</p>
        </div>
      </header>
    </aside>

    <div class="goa-main-flow">
      <div class="goa-screen-row" aria-label="Goa Kombucha Flow screens">
        {
          screens.slice(0, 3).map(([file, alt], index) => (
            <figure
              class="goa-screen-frame masonry-reveal"
              style={`--reveal-delay: ${Math.min(index * 45, 360)}ms`}
            >
              <img
                src={`${MEDIA}/${file}`}
                alt={alt}
                loading={index === 0 ? 'eager' : 'lazy'}
                fetchpriority={index === 0 ? 'high' : 'auto'}
                decoding="async"
              />
            </figure>
          ))
        }
      </div>

      <div class="goa-study-card masonry-reveal" style="--reveal-delay: 120ms">
        <article class="goa-block">
          <h2 class="goa-block__title">Project</h2>
          <hr class="goa-block__rule" />
          <div class="goa-block__body">
            {overviewParagraphs.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </article>
      </div>

      <div class="goa-screen-row" aria-label="More Goa Kombucha Flow screens">
        {
          screens.slice(3, 6).map(([file, alt], index) => (
            <figure
              class="goa-screen-frame masonry-reveal"
              style={`--reveal-delay: ${Math.min((index + 3) * 45, 360)}ms`}
            >
              <img src={`${MEDIA}/${file}`} alt={alt} loading="lazy" fetchpriority="auto" decoding="async" />
            </figure>
          ))
        }
      </div>

      <div class="goa-study-card masonry-reveal" style="--reveal-delay: 260ms">
        <article class="goa-block">
          <h2 class="goa-block__title">Key features</h2>
          <hr class="goa-block__rule" />
          <div class="goa-block__body">
            <ul class="goa-feature-list">
              {features.map((feature) => <li>{feature}</li>)}
            </ul>
          </div>
        </article>
      </div>

      <div class="goa-screen-row" aria-label="Additional Goa Kombucha Flow screens">
        {
          screens.slice(6, 9).map(([file, alt], index) => (
            <figure
              class="goa-screen-frame masonry-reveal"
              style={`--reveal-delay: ${Math.min((index + 6) * 45, 360)}ms`}
            >
              <img src={`${MEDIA}/${file}`} alt={alt} loading="lazy" fetchpriority="auto" decoding="async" />
            </figure>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  import '../../scripts/masonry-reveal.ts';
</script>

<style>
  :global(.project-detail-page) > .goa-project {
    width: 100%;
    max-width: min(100%, 1680px);
    margin-inline: auto;
    padding-inline: 20px;
    padding-block: clamp(0.5rem, 2vw, 1.5rem);
    gap: clamp(2.5rem, 7vw, 5.5rem);
  }

  .goa-layout {
    display: grid;
    grid-template-columns: minmax(18rem, 0.72fr) minmax(0, 1.58fr);
    gap: clamp(2rem, 4vw, 5rem);
    align-items: start;
  }

  .goa-sticky {
    position: sticky;
    top: clamp(1rem, 3vw, 2.5rem);
    min-width: 0;
  }

  .goa-headline {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .goa-headline h1 {
    max-width: 10ch;
    color: var(--text-primary);
    font-size: clamp(2.45rem, 5.5vw, 5.2rem);
    line-height: 0.94;
  }

  .goa-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .goa-tags li {
    border: 1px solid currentColor;
    border-radius: 999px;
    padding: 0.42rem 0.7rem;
    color: var(--text-primary);
    font-family: var(--font-family-display);
    font-size: 0.78rem;
    line-height: 1;
    text-transform: uppercase;
  }

  .goa-meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    max-width: 31ch;
    color: var(--text-secondary);
    font-family: var(--font-family-body);
    font-size: 0.95rem;
    font-weight: 300;
    line-height: 1.45;
  }

  .goa-meta p {
    margin: 0;
  }

  .goa-meta i {
    color: var(--text-primary);
    font-style: italic;
    text-transform: uppercase;
  }

  .goa-main-flow {
    --goa-flow-gap: clamp(2.4rem, 6vw, 4.5rem);
    --goa-soft-shadow:
      0 18px 42px rgba(35, 35, 35, 0.18),
      0 4px 12px rgba(35, 35, 35, 0.08);

    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: var(--goa-flow-gap);
  }

  .goa-screen-frame {
    margin: 0;
    overflow: hidden;
    border-radius: var(--project-card-radius);
    background: #f6f1eb;
    box-shadow: var(--goa-soft-shadow);
  }

  .goa-screen-frame img {
    display: block;
    width: 100%;
    height: auto;
  }

  .goa-study-card {
    display: flex;
    flex-direction: column;
    gap: clamp(2.4rem, 6vw, 4.5rem);
    padding: clamp(1.4rem, 2.8vw, 2.4rem);
    background: var(--palette-white);
    box-shadow: var(--goa-soft-shadow);
  }

  .goa-block__title {
    margin: 0;
    color: var(--text-primary);
    font-family: var(--font-family-display);
    font-size: clamp(1.1rem, 1.9vw, 1.7rem);
    font-weight: 400;
    letter-spacing: 0.04em;
    line-height: 1.05;
    text-transform: uppercase;
  }

  .goa-block__rule {
    width: 100%;
    height: 0;
    margin: clamp(0.8rem, 1.6vw, 1.2rem) 0 clamp(1.2rem, 2.6vw, 2rem);
    border: 0;
    border-top: 1px solid color-mix(in srgb, var(--text-primary) 26%, transparent);
  }

  .goa-block__body {
    display: flex;
    width: min(100%, 62ch);
    margin-left: auto;
    flex-direction: column;
    gap: 1rem;
    color: var(--text-secondary);
    font-family: var(--font-family-body);
    font-weight: 300;
  }

  .goa-block__body p {
    margin: 0;
    font-size: 1rem;
    line-height: 1.65;
  }

  .goa-feature-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .goa-feature-list li {
    padding-bottom: 0.75rem;
    border-bottom: 1px solid color-mix(in srgb, var(--text-primary) 14%, transparent);
    line-height: 1.55;
  }

  .goa-feature-list li:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .goa-screen-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(0.9rem, 1.8vw, 1.4rem);
    align-items: start;
  }

  @media (max-width: 960px) {
    .goa-layout {
      grid-template-columns: 1fr;
      gap: clamp(1.5rem, 5vw, 3rem);
    }

    .goa-sticky {
      position: static;
    }

    .goa-headline h1 {
      max-width: none;
      font-size: clamp(2.7rem, 14vw, 4.8rem);
    }

    .goa-meta {
      max-width: none;
    }

    .goa-block__body {
      width: 100%;
      margin-left: 0;
    }

    .goa-screen-row {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .goa-screen-row {
      grid-template-columns: 1fr;
    }
  }
</style>
