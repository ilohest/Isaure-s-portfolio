---
import ResponsiveImage from '../media/ResponsiveImage.astro';
import type { ImageMetadata } from 'astro';

const images = import.meta.glob<ImageMetadata>(
  '/src/assets/media-src/projects/branding/baud/*.png',
  { eager: true, import: 'default' },
);
const pic = (base: string): ImageMetadata =>
  images[`/src/assets/media-src/projects/branding/baud/${base}.png`];

type Swatch = { hex: string; rgb: string; cmyk: string; textColor: string };
type Item =
  | { type: 'card'; title?: string; mono?: boolean; paragraphs: string[] }
  | { type: 'palette'; swatches: Swatch[] }
  | { type: 'image'; base: string; alt: string };

const items: Item[] = [
  { type: 'image', base: 'Fichier 18', alt: 'Baud Architects — Visual' },
  { type: 'image', base: 'Fichier 19', alt: 'Baud Architects — Visual' },
  { type: 'image', base: 'Fichier 20', alt: 'Baud Architects — Visual' },
  { type: 'image', base: 'Fichier 35', alt: 'Baud Architects — Visual' },
  { type: 'card', title: 'Concept', paragraphs: [
    'The identity is built around the idea that every architectural project has its own distinctive silhouette.',
    'Instead of creating a single static logo, the branding introduces a system where each project receives a unique graphic profile derived from the geometry of the building.',
    'These simplified line drawings translate architectural volumes into abstract graphic elements. Each profile becomes a visual signature for the project while remaining part of the same visual language.',
    'This approach allows the identity to evolve organically alongside the studio’s portfolio.',
  ] },
  { type: 'image', base: 'Fichier 21', alt: 'Baud Architects — Visual' },
  { type: 'card', title: 'The Logo', paragraphs: [
    'The BAUD logotype uses a contemporary geometric typeface that emphasizes clarity and balance.',
    'Its clean curves and generous spacing convey precision and professionalism — values central to architectural practice.',
    'At the heart of the identity lies a stylized “a”, extracted from the logotype itself. This symbol becomes the distinctive element of the brand.',
    'Its continuous rounded form evokes architectural lines and structural fluidity while maintaining a strong visual simplicity.',
  ] },
  { type: 'image', base: 'Fichier 22', alt: 'Baud Architects — Visual' },
  { type: 'image', base: 'Group 24', alt: 'Baud Architectes — Visual' },
  { type: 'card', title: 'The Project Marker', paragraphs: [
    'The stylized “a” also functions as a project marker within the identity system.',
    'When paired with a project name, it acts as a visual indicator — similar to the logic of a digital tag or “@”.',
    'This creates a clear connection between the studio and its individual projects while maintaining a consistent brand language.',
    'The symbol becomes both a signature and a navigational element within the studio’s communication.',
  ] },
  { type: 'image', base: 'Fichier 23', alt: 'Baud Architects — Visual' },
  { type: 'image', base: 'Fichier 24', alt: 'Baud Architects — Visual' },
  { type: 'image', base: 'Fichier 32', alt: 'Baud Architects — Visual' },
  { type: 'card', title: 'Graphic Profiles', paragraphs: [
    'Each architectural project is represented by a unique graphic profile derived from its characteristic forms.',
    'These line-based icons abstract key structural elements of the buildings — façades, angles, volumes, or silhouettes.',
    'Together they create a visual library of architectural identities linked to the studio’s work.',
  ] },
  { type: 'image', base: 'Fichier 30', alt: 'Baud Architects — Visual' },
  { type: 'card', title: 'Applications', paragraphs: [
    'The identity is designed to function across architectural contexts — from construction sites to presentation documents.',
    'Large-scale applications such as construction banners reinforce visibility on site, while printed materials maintain a refined and professional aesthetic.',
    'The minimal graphic language ensures clarity across both technical and visual communication.',
  ] },
  { type: 'image', base: 'Construction_Banner_Mockup', alt: 'Baud Architects — Construction banner' },
  { type: 'image', base: 'paper logo mockup', alt: 'Baud Architects — Logo mockup' },
  { type: 'image', base: 'Fichier 31', alt: 'Baud Architects — Visual' },
  { type: 'card', title: 'Result', paragraphs: [
    'The result is a modular visual identity that mirrors the nature of architectural practice: structured, adaptable, and evolving with each project.',
    'Rather than a static logo, the system becomes a living archive of the studio’s architecture.',
  ] },
  { type: 'image', base: 'Fichier 46', alt: 'Baud Architects — Visual' },
  { type: 'image', base: 'Group 27', alt: 'Baud Architects — Visual' },
  { type: 'image', base: 'A4paper', alt: 'Baud Architects — Visual' },
  { type: 'image', base: 'Construction Cap', alt: 'Baud Architects — Construction cap' },
  { type: 'image', base: 'Free Letter Size PSD Flyer Mockup Design For Branding', alt: 'Baud Architects — Flyer mockup' },
  { type: 'image', base: 'Wrinkled_Construction_Banner_Mockup', alt: 'Baud Architects — Banner mockup' },
  { type: 'image', base: 'construction fence', alt: 'Baud Architects — Construction fence' },
  { type: 'palette', swatches: [
    { hex: '#1F1F21', rgb: '31, 31, 33', cmyk: '6, 6, 0, 87', textColor: '#F4F4F2' },
    { hex: '#F4F4F2', rgb: '244, 244, 242', cmyk: '0, 0, 1, 4', textColor: '#1F1F21' },
    { hex: '#C6DCDA', rgb: '198, 220, 218', cmyk: '10, 0, 1, 14', textColor: '#1F1F21' },
    { hex: '#0C4651', rgb: '12, 70, 81', cmyk: '85, 14, 0, 68', textColor: '#F4F4F2' },
    { hex: '#CAF567', rgb: '202, 245, 103', cmyk: '18, 0, 58, 4', textColor: '#1F1F21' },
  ] },
  { type: 'card', title: 'Color palette', paragraphs: [
    'The color palette reflects the balance between architectural rigor and contemporary sensibility.',
    'A deep charcoal forms the foundation of the identity, conveying precision, stability, and professionalism. It is paired with an off-white tone that softens the composition and introduces a sense of clarity and space — much like the neutral materials often found in architectural environments.',
    'Cool teal and muted aqua tones introduce a subtle reference to construction materials, technical drawings, and urban landscapes. These colors bring depth to the identity while maintaining a restrained and professional aesthetic.',
    'A vibrant lime accent is used sparingly to introduce contrast and highlight key elements, adding a modern and dynamic touch to the otherwise minimal palette.',
  ] },
  { type: 'card', title: 'Typography', paragraphs: [
    'The typographic system combines elegance with functional clarity.',
    'Floreal, used for titles and headings, introduces a refined editorial tone. Its distinctive serif shapes bring sophistication and character to the identity, reinforcing the studio’s positioning within a design-driven architectural context.',
    'For body text, Corbel provides balance through a clean and highly legible sans-serif structure. Its neutral geometry ensures clarity across documents, presentations, and technical communication.',
    'Together, the combination of Floreal and Corbel creates a dialogue between expression and precision — reflecting the balance between creativity and structure inherent to architectural practice.',
  ] },
];

const masonrySizes = '(min-width: 970px) 28vw, (min-width: 628px) 44vw, 92vw';
const delay = (i: number) => `${Math.min(i * 32, 420)}ms`;

const projectParagraphs = [
  'Baud Architectes is an architectural studio working across architecture, urbanism, expertise, and design consulting.',
  'The objective of this branding exploration was to create a visual identity that reflects the studio’s architectural thinking: structured, precise, and adaptable to a wide variety of projects.',
  'The challenge was to design an identity system capable of evolving with each project while maintaining a strong and recognizable brand signature.',
];

---

<section class="baud-project relative flex flex-col">
  <div class="baud-layout">
    <aside class="baud-sticky">
      <header class="baud-headline">
        <p class="project-title-reveal baud-title font-display m-0 uppercase" aria-hidden="true">
          <span class="project-title-reveal__inner">Baud</span>
        </p>
        <ul class="baud-tags" aria-label="Project tags">
          <li>Branding</li>
          <li>Art direction</li>
          <li>Identity system</li>
        </ul>
        <div class="baud-meta" aria-label="Project details">
          <p><i>Client: </i>Baud Architects</p>
          <p><i>Sector: </i>Urban architecture</p>
          <p><i>Country: </i>Belgium</p>
          <p><i>Format: </i>Concept proposal</p>
        </div>
      </header>
    </aside>

    <div class="baud-main-flow">
      <figure class="baud-hero">
        <ResponsiveImage
          src={pic('Group 106')}
          alt="Baud Architectes modular visual identity cover"
          sizes="(min-width: 1280px) 64vw, (min-width: 970px) calc(100vw - 24rem), calc(100vw - 2rem)"
          loading="eager"
          fetchpriority="high"
          class="baud-hero-picture"
          imgClass="baud-hero-img"
        />
      </figure>

      <section class="baud-study-card masonry-reveal" aria-label="Baud case study">
        <article class="baud-block">
          <h2 class="baud-block__title">Project</h2>
          <hr class="baud-block__rule" />
          <div class="baud-block__body">
            {projectParagraphs.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </article>

        <article class="baud-block">
          <h2 class="baud-block__title">Responsibilities</h2>
          <hr class="baud-block__rule" />
          <div class="baud-block__body">
            <p>Visual identity - Art direction - Logo system - Brand applications</p>
          </div>
        </article>
      </section>

      <section
        class="baud-masonry"
        data-masonry
        data-cols-desktop="3"
        data-cols-tablet="2"
        data-cols-mobile="1"
        aria-label="Baud visual identity gallery"
      >
        {
          items.map((item, i) => (
            <article class="masonry-item masonry-reveal" style={`--reveal-delay: ${delay(i)}`}>
              {item.type === 'image' && (
                <ResponsiveImage src={pic(item.base)} alt={item.alt} sizes={masonrySizes} loading="lazy" fetchpriority="low" imgClass="baud-masonry-media" />
              )}

              {item.type === 'palette' && (
                <div class="palette-card" role="group" aria-label="Baud Architectes color palette">
                  <div class="palette-grid">
                    {item.swatches.map((sw) => (
                      <div class="palette-swatch" style={`background-color:${sw.hex};color:${sw.textColor}`}>
                        <div class="palette-label">
                          <p class="palette-line">HEX {sw.hex}</p>
                          <p class="palette-line">RGB {sw.rgb}</p>
                          <p class="palette-line">CMYK {sw.cmyk}</p>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              )}

              {item.type === 'card' && (
                <div class="baud-note-card">
                  {item.title && item.title.trim() && <h3>{item.title}</h3>}
                  {item.title && item.title.trim() && <hr class="baud-note-card__rule" />}
                  <div class="baud-note-card__body">
                    {item.paragraphs.map((p) => (
                      <p class={item.mono ? 'baud-intro' : ''}>{p}</p>
                    ))}
                  </div>
                </div>
              )}
            </article>
          ))
        }
      </section>

    </div>
  </div>
</section>

<script>
  import '../../scripts/masonry-columns.ts';
  import '../../scripts/masonry-reveal.ts';
</script>

<style>
  :global(.project-detail-page) > .baud-project {
    width: 100%;
    max-width: min(100%, 1680px);
    margin-inline: auto;
    padding-inline: 20px;
    padding-block: clamp(0.5rem, 2vw, 1.5rem);
  }

  .baud-layout {
    display: grid;
    grid-template-columns: minmax(18rem, 0.72fr) minmax(0, 1.58fr);
    gap: clamp(2rem, 4vw, 5rem);
    align-items: start;
  }

  .baud-sticky {
    position: sticky;
    top: clamp(1rem, 3vw, 2.5rem);
    min-width: 0;
  }

  .baud-headline {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .baud-title {
    max-width: 8ch;
    color: var(--text-primary);
    font-size: clamp(2.8rem, 6vw, 5.2rem);
    line-height: 0.92;
  }

  .baud-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .baud-tags li {
    border: 1px solid currentColor;
    border-radius: 999px;
    padding: 0.42rem 0.7rem;
    color: var(--text-primary);
    font-family: var(--font-family-display);
    font-size: 0.78rem;
    line-height: 1;
    text-transform: uppercase;
  }

  .baud-meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    max-width: 31ch;
    color: var(--text-secondary);
    font-family: var(--font-family-body);
    font-size: 0.95rem;
    font-weight: 300;
    line-height: 1.45;
  }

  .baud-meta p {
    margin: 0;
  }

  .baud-meta i {
    color: var(--text-primary);
    font-style: italic;
    text-transform: uppercase;
  }

  .baud-main-flow {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: clamp(2.4rem, 6vw, 4.5rem);
  }

  .baud-hero {
    overflow: hidden;
    width: 100%;
    margin: 0;
    border-radius: var(--project-card-radius);
    background: #fff;
    box-shadow:
      0 18px 42px rgba(35, 35, 35, 0.12),
      0 4px 12px rgba(35, 35, 35, 0.07);
  }

  .baud-hero :global(.baud-hero-picture) {
    display: block;
  }

  .baud-hero :global(.baud-hero-img) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0;
    background: #fff;
  }

  .baud-study-card {
    display: flex;
    width: 100%;
    flex-direction: column;
    gap: clamp(2.4rem, 6vw, 4.5rem);
    padding: clamp(1.4rem, 2.8vw, 2.4rem);
    margin-block: clamp(0.4rem, 1.6vw, 1.4rem);
    background: var(--palette-white);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
  }

  .baud-block__title {
    margin: 0;
    color: var(--text-primary);
    font-family: var(--font-family-display);
    font-size: clamp(1.1rem, 1.9vw, 1.7rem);
    font-weight: 400;
    letter-spacing: 0.04em;
    line-height: 1.05;
    text-transform: uppercase;
  }

  .baud-block__rule {
    width: 100%;
    height: 0;
    margin: clamp(0.8rem, 1.6vw, 1.2rem) 0 clamp(1.2rem, 2.6vw, 2rem);
    border: 0;
    border-top: 1px solid color-mix(in srgb, var(--text-primary) 26%, transparent);
  }

  .baud-block__body {
    display: flex;
    width: min(100%, 62ch);
    margin-left: auto;
    flex-direction: column;
    gap: 1rem;
    color: var(--text-secondary);
    font-family: var(--font-family-body);
    font-weight: 300;
  }

  .baud-block__body p {
    margin: 0;
    font-size: 1rem;
    line-height: 1.65;
  }

  .baud-masonry {
    display: flex;
    gap: clamp(0.75rem, 1.8vw, 1rem);
    align-items: flex-start;
    border-radius: var(--project-card-radius);
  }

  .baud-masonry :global(.masonry-col) {
    flex: 1 1 0;
    min-width: 0;
  }

  .baud-masonry :global(.baud-masonry-media),
  .baud-masonry .palette-card,
  .baud-note-card {
    width: 100%;
    border-radius: var(--project-card-radius);
  }

  .baud-masonry :global(.baud-masonry-media) {
    display: block;
    height: auto;
    background: #fff;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
  }

  .baud-note-card {
    padding: clamp(1.4rem, 2.8vw, 2.4rem);
    background: var(--palette-white);
    color: var(--text-secondary);
    font-family: var(--font-family-body);
    font-weight: 300;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
  }

  .baud-note-card h3 {
    margin: 0;
    color: var(--text-primary);
    font-family: var(--font-family-display);
    font-size: clamp(1.1rem, 1.9vw, 1.7rem);
    font-weight: 400;
    letter-spacing: 0.04em;
    line-height: 1.05;
    text-transform: uppercase;
  }

  .baud-note-card__rule {
    width: 100%;
    height: 0;
    margin: clamp(0.8rem, 1.6vw, 1.2rem) 0 clamp(1.2rem, 2.6vw, 2rem);
    border: 0;
    border-top: 1px solid color-mix(in srgb, var(--text-primary) 26%, transparent);
  }

  .baud-note-card__body {
    display: flex;
    width: min(100%, 62ch);
    margin-left: auto;
    flex-direction: column;
    gap: 1rem;
  }

  .baud-note-card p {
    margin: 0;
    font-size: 1rem;
    line-height: 1.65;
  }

  .baud-intro {
    font-size: clamp(1.25rem, 1.9vw, 1.6rem);
    line-height: 1.15;
    text-transform: uppercase;
    transition: letter-spacing 220ms ease;
  }

  .masonry-item:hover .baud-intro {
    letter-spacing: 0.08em;
  }

  /* Palette */
  .palette-card {
    overflow: hidden;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
  }

  .palette-grid {
    display: flex;
    width: 100%;
    flex-direction: column;
  }

  .palette-swatch {
    position: relative;
    flex: 1 1 0;
    min-width: 0;
    min-height: 90px;
    display: flex;
    align-items: flex-end;
    transition:
      flex-grow 260ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 260ms cubic-bezier(0.22, 1, 0.36, 1),
      filter 260ms ease;
  }

  .palette-label {
    padding: 1rem;
    line-height: 1.25;
    letter-spacing: 0.01em;
    transition:
      padding 260ms cubic-bezier(0.22, 1, 0.36, 1),
      letter-spacing 260ms ease,
      transform 260ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .palette-line {
    margin: 0;
    white-space: nowrap;
    font-size: 0.9rem;
    transition:
      letter-spacing 260ms ease,
      transform 260ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .palette-swatch:hover {
    flex-grow: 1.18;
    transform: scale(1.035);
    filter: saturate(1.08) brightness(1.02);
    z-index: 1;
  }

  .palette-swatch:hover .palette-label {
    padding: 1.2rem;
    letter-spacing: 0.06em;
    transform: translateY(-2px);
  }

  .palette-swatch:hover .palette-line {
    letter-spacing: 0.08em;
    transform: scale(1.03);
  }

  @media (max-width: 960px) {
    .baud-layout {
      grid-template-columns: 1fr;
      gap: clamp(1.5rem, 5vw, 3rem);
    }

    .baud-sticky {
      position: static;
    }

    .baud-title {
      max-width: none;
      font-size: clamp(2.7rem, 15vw, 4.8rem);
    }

    .baud-meta,
    .baud-block__body {
      max-width: none;
      width: 100%;
      margin-left: 0;
    }
  }

  @media (max-width: 628px) {
    .baud-masonry {
      flex-direction: column;
      gap: 0.75rem;
    }

    .palette-swatch {
      min-height: 80px;
    }

    .baud-study-card {
      gap: 2rem;
    }
  }
</style>
