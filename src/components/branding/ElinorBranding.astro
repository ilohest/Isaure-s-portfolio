---
import ResponsiveImage from '../media/ResponsiveImage.astro';

interface PictureImport {
  sources: { avif?: string; webp?: string };
  img: { src: string; w: number; h: number };
}

const images = import.meta.glob<PictureImport>(
  '/src/assets/media-src/projects/branding/elinor/*.png',
  { eager: true, import: 'default', query: { w: '640;960;1280;1920', format: 'avif;webp', as: 'picture' } },
);
const pic = (base: string): PictureImport =>
  images[`/src/assets/media-src/projects/branding/elinor/${base}.png`];

// Galerie justified : ratio d'aspect calculé au build (w/h) × biais de mise en page.
const galleryItems: { base: string; alt: string; layoutBias?: number }[] = [
  { base: 'elinor-hands-campaign', alt: 'Elinor hands campaign visual', layoutBias: 0.92 },
  { base: 'elinor-cover-photo', alt: 'Elinor social cover image', layoutBias: 1.04 },
  { base: 'elinor-logo-light', alt: 'Elinor van de Werve light logo composition', layoutBias: 1.02 },
  { base: 'elinor-business-cards', alt: 'Elinor business cards mockup' },
  { base: 'elinor-icon-blue', alt: 'Elinor icon on blue background', layoutBias: 1.06 },
  { base: 'elinor-instagram-profile', alt: 'Elinor Instagram profile overview', layoutBias: 0.7 },
  { base: 'elinor-post-01', alt: 'Elinor Instagram post 1', layoutBias: 0.82 },
  { base: 'elinor-instagram-main', alt: 'Elinor Instagram main feed view', layoutBias: 0.7 },
  { base: 'elinor-post-02', alt: 'Elinor Instagram post 2', layoutBias: 0.82 },
  { base: 'elinor-instagram-search-picks', alt: 'Elinor Instagram search picks view', layoutBias: 0.7 },
  { base: 'elinor-post-03', alt: 'Elinor Instagram post 3', layoutBias: 0.82 },
  { base: 'elinor-story-08', alt: 'Elinor Instagram story design 8', layoutBias: 0.68 },
  { base: 'elinor-post-05', alt: 'Elinor Instagram post 5', layoutBias: 0.82 },
  { base: 'elinor-instagram-story-ui', alt: 'Elinor Instagram story interface view', layoutBias: 0.7 },
  { base: 'elinor-post-07', alt: 'Elinor Instagram post 7', layoutBias: 0.82 },
  { base: 'elinor-post-08', alt: 'Elinor Instagram post 8', layoutBias: 0.82 },
  { base: 'elinor-brandbook-spread-08', alt: 'Elinor brandbook spread 8', layoutBias: 1.14 },
  { base: 'elinor-brandbook-spread-05', alt: 'Elinor brandbook spread 5', layoutBias: 1.32 },
  { base: 'elinor-post-09', alt: 'Elinor Instagram post 9', layoutBias: 0.82 },
  { base: 'elinor-post-10', alt: 'Elinor Instagram post 10', layoutBias: 0.82 },
  { base: 'elinor-post-11', alt: 'Elinor Instagram post 11', layoutBias: 0.82 },
  { base: 'elinor-post-12', alt: 'Elinor Instagram post 12', layoutBias: 0.82 },
  { base: 'elinor-brandbook-spread-22', alt: 'Elinor brandbook spread 22', layoutBias: 1.14 },
];

const aspectRatio = (base: string, bias = 1): number => {
  const p = pic(base);
  const ar = p && p.img.h ? (p.img.w / p.img.h) * bias : bias;
  return Math.max(ar, 0.3);
};
---

<section class="elinor-project relative container mx-auto flex flex-col gap-4 px-4 py-4">
  <!-- Hero -->
  <div class="flex items-center justify-center">
    <ResponsiveImage
      img={pic('elinor-logo-blue')}
      alt="Elinor van de Werve blue logo composition"
      sizes="(min-width: 1280px) 1200px, (min-width: 768px) calc(100vw - 5rem), calc(100vw - 2rem)"
      loading="eager"
      fetchpriority="high"
      imgClass="border-round-xl block h-auto max-w-full md:m-8"
    />
  </div>

  <!-- Project summary -->
  <div class="project-summary-card">
    <div class="project-summary-grid">
      <div class="project-summary-meta">
        <section>
          <h3>Responsibilities</h3>
          <ul class="project-summary-list">
            <li>Visual identity</li>
            <li>Art direction</li>
            <li>Social network templates</li>
          </ul>
        </section>
        <section>
          <h3>About</h3>
          <div class="project-summary-about">
            <p><i>Client: </i>Elinor kinésiologie</p>
            <p><i>Sector: </i>Health &amp; wellness</p>
            <p><i>Country: </i>Belgium</p>
          </div>
        </section>
      </div>

      <div class="project-summary-copy">
        <h3>Project</h3>
        <p>
          Elinor Kinesiology offers personalized holistic care that gently balances body and mind
          through expert muscle-response testing and tailored energy techniques. Elinor creates a
          nurturing environment for expectant mothers, alleviating stress, easing tension, and
          promoting optimal well-being for both mother and baby. Elinor's compassionate approach
          adapts the unique needs of the patients, guiding them toward a more harmonious, energized,
          and empowered journey.
        </p>
      </div>

      <div class="project-summary-copy project-summary-branding">
        <h3>Branding</h3>
        <p>
          This logo is built on a continuous, flowing line that forms an infinity loop, an
          intentional nod to the unending cycle of energy in the body. Its shape subtly echoes the
          therapist's hands in motion, listening and responding to the body's own signals. By
          bridging earth and sky, the logo embodies restored balance and the seamless connection
          between physical sensation and emotional well-being. With its clean, organic form, it
          communicates professionalism, trust, and the core kinesiological promise of guiding clients
          back to their natural state of harmony. The typography uses slender, elegant typefaces with
          generous letter-spacing, projecting both precision and refinement. The color palette is
          built from soft pastels, muted tones that work together to soothe the senses and reinforce
          the brand's promise of balanced, restorative care.
        </p>
      </div>
    </div>
  </div>

  <!-- Justified gallery (mise en page par justified-gallery.ts) -->
  <section class="justified-gallery" data-justified>
    {
      galleryItems.map((item) => (
        <article
          class="justified-item masonry-reveal"
          data-ar={aspectRatio(item.base, item.layoutBias).toFixed(4)}
        >
          <div class="justified-media-link">
            <ResponsiveImage
              img={pic(item.base)}
              alt={item.alt}
              sizes="100vw"
              loading="lazy"
              imgClass="justified-media"
            />
          </div>
        </article>
      ))
    }
  </section>
</section>

<script>
  import '../../scripts/justified-gallery.ts';
  import '../../scripts/masonry-reveal.ts';
</script>

<style>
  .justified-gallery {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    opacity: 0;
    transition: opacity 0.24s ease;
  }

  .justified-gallery.is-ready {
    opacity: 1;
  }

  .justified-gallery :global(.justified-row) {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .justified-item {
    min-width: 0;
    flex: 0 0 auto;
  }

  .justified-item :global(picture) {
    display: block;
  }

  .justified-media-link {
    display: block;
    overflow: hidden;
    text-decoration: none;
    border-radius: var(--project-card-radius);
    border: 1px solid var(--surface-muted);
    background: #f7efe4;
  }

  .justified-item :global(.justified-media) {
    width: 100%;
    display: block;
    border-radius: var(--project-card-radius);
  }

  @media (max-width: 960px) {
    .justified-gallery,
    .justified-gallery :global(.justified-row) {
      gap: 0.75rem;
    }
  }

  @media (max-width: 640px) {
    .justified-gallery,
    .justified-gallery :global(.justified-row) {
      gap: 0.625rem;
    }
  }
</style>
