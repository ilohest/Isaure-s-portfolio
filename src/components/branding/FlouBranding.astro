---
import ResponsiveImage from '../media/ResponsiveImage.astro';

interface PictureImport {
  sources: { avif?: string; webp?: string };
  img: { src: string; w: number; h: number };
}

// Toutes les sources flou optimisées au build (AVIF/WebP multi-largeurs).
const images = import.meta.glob<PictureImport>(
  '/src/assets/media-src/projects/branding/flou/*.png',
  {
    eager: true,
    import: 'default',
    query: { w: '640;960;1280;1920', format: 'avif;webp', as: 'picture' },
  },
);

const pic = (base: string): PictureImport =>
  images[`/src/assets/media-src/projects/branding/flou/${base}.png`];

// Masonry (ordre conservé depuis FlouBranding.vue).
const flouImages: { base: string; alt: string; noRadius?: boolean }[] = [
  { base: 'flou-1', alt: 'Flou 1' },
  { base: 'flou-15', alt: 'Flou 15' },
  { base: 'flou-2', alt: 'Flou 2' },
  { base: 'flou-3', alt: 'Flou 3' },
  { base: 'flou-16', alt: 'Flou 16' },
  { base: 'flou-4', alt: 'Flou 4' },
  { base: 'flou-17', alt: 'Flou 17' },
  { base: 'flou-5', alt: 'Flou 5' },
  { base: 'flou-6', alt: 'Flou 6' },
  { base: 'flou-21', alt: 'Flou 21', noRadius: true },
  { base: 'flou-13', alt: 'Flou 13' },
  { base: 'flou-7', alt: 'Flou 7' },
  { base: 'flou-8', alt: 'Flou 8' },
  { base: 'flou-9', alt: 'Flou 9' },
  { base: 'flou-10', alt: 'Flou 10' },
  { base: 'flou-12', alt: 'Flou 12' },
  { base: 'flou-11', alt: 'Flou 11' },
  { base: 'flou-14', alt: 'Flou 14' },
  { base: 'flou-18', alt: 'Flou 18' },
  { base: 'flou-19', alt: 'Flou 19' },
  { base: 'flou-20', alt: 'Flou 20' },
  { base: 'flou-22', alt: 'Flou 22' },
  { base: 'flou-palette', alt: 'Flou palette' },
];

const masonrySizes = '(max-width: 628px) 50vw, (max-width: 970px) 33vw, 25vw';
---

<section class="relative container mx-auto flex flex-col gap-4 px-4 py-4">
  <!-- HERO responsive (AVIF/WEBP + fallback) -->
  <div class="flou-hero m-0 flex items-center justify-center p-0 md:my-6">
    <ResponsiveImage
      img={pic('flou-hero')}
      alt="Flou"
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      class="flou-hero-picture"
      imgClass="flou-hero-img border-round-xl block h-auto max-w-full bg-[#fff] p-4 md:p-8"
    />
  </div>

  <!-- Project summary -->
  <div
    class="p-card project-summary-card bg-[var(--surface-muted)] font-['Red_Hat_Text'] font-light text-[var(--text-secondary)] shadow-none"
  >
    <div class="p-card-body">
      <div class="p-card-content">
        <div class="flex flex-col gap-4 p-4 md:flex-row md:p-6">
          <div class="flex w-full flex-col gap-4 md:w-3/12">
            <section>
              <h3 class="mb-2 uppercase">Responsibilities</h3>
              <ul class="list-inside list-disc pl-6 text-base">
                <li>Visual identity</li>
                <li>Art direction</li>
              </ul>
            </section>

            <section>
              <h3 class="mb-2 uppercase">About</h3>
              <div class="flex flex-col gap-1 text-base">
                <p><i class="uppercase">Client: </i>Flouwers</p>
                <p><i class="uppercase">Sector: </i>Floral scenography</p>
                <p><i class="uppercase">Country: </i>Belgium</p>
                <p>
                  <i class="uppercase">Instagram: </i>
                  <a href="https://www.instagram.com/f.lou.wers/" target="_blank" class="text-inherit"
                    >@f.lou.wers</a
                  >
                </p>
              </div>
            </section>
          </div>

          <div class="md:w-4/12">
            <h3 class="mb-2 uppercase">Project</h3>
            <p>
              Flou brings a poetic touch to floral design, where emotion meets artistry. Founded by
              Mary-Lou, this Brussels-based floral studio crafts refined, imaginative compositions
              that blend texture, color, and whimsy in perfect balance. From bespoke bouquets to
              immersive event scenography, every creation embodies her signature mix of intuition
              and precision. Whether for weddings, birthdays, or intimate gatherings, Flou
              transforms spaces into living art, fleeting yet unforgettable.
            </p>
          </div>

          <div class="md:w-5/12">
            <h3 class="mb-2 tracking-wide uppercase">Branding</h3>
            <p>
              The identity of Flou translates Mary-Lou’s floral world into a sensory, living brand.
              The logo, composed of organic petals cut from a rectangle, captures both structure and
              spontaneity, like a bouquet balanced between precision and wildness. Its negative
              space allows it to morph with its background, blending into photographs and textures to
              echo the natural flow of petals, light, and movement. Typography combines softness and
              character. The color palette — a dialogue between mulberry, dark purple, and moss green
              — celebrates nature in all its contrasts: lush, daring, and tender. The result is a
              brand that feels alive, playful yet elegant, earthy yet poetic. "Moitié Lou, moitié
              fou, 100% Flou".
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Masonry optimisé -->
  <section class="masonry">
    {
      flouImages.map((img, index) => (
        <div
          class="masonry-item masonry-reveal"
          style={`--reveal-delay: ${Math.min(index * 35, 420)}ms`}
        >
          <ResponsiveImage
            img={pic(img.base)}
            alt={img.alt}
            sizes={masonrySizes}
            loading="lazy"
            fetchpriority="low"
            imgClass={img.noRadius ? 'no-radius' : undefined}
          />
        </div>
      ))
    }
  </section>

  <!-- Brandbook bas de page -->
  <ResponsiveImage
    img={pic('flou-brandbook')}
    alt="Flou brandbook"
    sizes="100vw"
    loading="lazy"
    fetchpriority="low"
    imgClass="border-round-xl block h-auto w-full max-w-full"
  />
</section>

<script>
  import '../../scripts/masonry-reveal.ts';
</script>

<style>
  .masonry {
    column-count: 4;
    column-gap: 1rem;
    border-radius: var(--project-card-radius);
  }

  .masonry-item :global(picture),
  .masonry-item :global(img) {
    content-visibility: auto;
    contain-intrinsic-size: 800px auto;
  }

  .masonry-item {
    break-inside: avoid;
    -webkit-column-break-inside: avoid;
    page-break-inside: avoid;
    margin-bottom: 1rem;
  }

  .masonry-item :global(img) {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--image-radius);
  }

  .masonry-reveal {
    opacity: 0;
    transform: translate3d(0, 24px, 0) scale(0.985);
    transition:
      opacity 520ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 680ms cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: var(--reveal-delay, 0ms);
    will-change: opacity, transform;
  }

  .masonry-reveal.is-visible {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }

  @media (max-width: 970px) {
    .masonry {
      column-count: 3;
    }
  }

  @media (max-width: 628px) {
    .masonry {
      column-count: 2;
      column-gap: 0.75rem;
    }
  }

  .masonry-item :global(img.no-radius),
  :global(img.no-radius) {
    border-radius: 0 !important;
  }

  @media (max-width: 628px) {
    .flou-hero {
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
    }

    .flou-hero :global(.flou-hero-picture) {
      display: block;
      width: 100%;
    }

    .flou-hero :global(.flou-hero-img) {
      width: 100%;
      max-width: 100% !important;
      padding: 0 !important;
      border-radius: 0 !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .masonry-reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
