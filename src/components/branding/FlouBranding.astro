---
import ResponsiveImage from '../media/ResponsiveImage.astro';
import flouHero from '/src/assets/media-src/projects/branding/flou/flou-hero.png';
import type { ImageMetadata } from 'astro';

const images = import.meta.glob<ImageMetadata>(
  '/src/assets/media-src/projects/branding/flou/*.png',
  { eager: true, import: 'default' },
);

const pic = (base: string): ImageMetadata =>
  images[`/src/assets/media-src/projects/branding/flou/${base}.png`];

// Masonry (ordre conservé).
const flouImages: { base: string; alt: string; noRadius?: boolean }[] = [
  { base: 'flou-1', alt: 'Flou 1' },
  { base: 'flou-15', alt: 'Flou 15' },
  { base: 'flou-2', alt: 'Flou 2' },
  { base: 'flou-3', alt: 'Flou 3' },
  { base: 'flou-16', alt: 'Flou 16' },
  { base: 'flou-4', alt: 'Flou 4' },
  { base: 'flou-5', alt: 'Flou 5' },
  { base: 'flou-6', alt: 'Flou 6' },
  { base: 'flou-21', alt: 'Flou 21', noRadius: true },
  { base: 'flou-13', alt: 'Flou 13' },
  { base: 'flou-7', alt: 'Flou 7' },
  { base: 'flou-8', alt: 'Flou 8' },
  { base: 'flou-9', alt: 'Flou 9' },
  { base: 'flou-10', alt: 'Flou 10' },
  { base: 'flou-12', alt: 'Flou 12' },
  { base: 'flou-11', alt: 'Flou 11' },
  { base: 'flou-14', alt: 'Flou 14' },
  { base: 'flou-18', alt: 'Flou 18' },
  { base: 'flou-19', alt: 'Flou 19' },
  { base: 'flou-20', alt: 'Flou 20' },
  { base: 'flou-22', alt: 'Flou 22' },
  { base: 'flou-palette', alt: 'Flou color palette' },
];

const masonrySizes = '(min-width: 970px) 28vw, (min-width: 628px) 44vw, 92vw';
const delay = (i: number) => `${Math.min(i * 32, 420)}ms`;

const projectParagraphs = [
  'Flou brings a poetic touch to floral design, where emotion meets artistry. Founded by Mary-Lou, this Brussels-based floral studio crafts refined, imaginative compositions that blend texture, color, and whimsy in perfect balance.',
  'From bespoke bouquets to immersive event scenography, every creation embodies her signature mix of intuition and precision. Whether for weddings, birthdays, or intimate gatherings, Flou transforms spaces into living art, fleeting yet unforgettable.',
];

const brandingParagraphs = [
  'The identity of Flou translates Mary-Lou’s floral world into a sensory, living brand. The logo, composed of organic petals cut from a rectangle, captures both structure and spontaneity, like a bouquet balanced between precision and wildness.',
  'Its negative space allows it to morph with its background, blending into photographs and textures to echo the natural flow of petals, light, and movement. Typography combines softness and character, while the palette — a dialogue between mulberry, dark purple, and moss green — celebrates nature in all its contrasts: lush, daring, and tender.',
  'The result is a brand that feels alive, playful yet elegant, earthy yet poetic. “Moitié Lou, moitié fou, 100% Flou”.',
];
---

<section class="flou-project relative flex flex-col">
  <div class="flou-layout">
    <aside class="flou-sticky">
      <header class="flou-headline">
        <p class="project-title-reveal flou-title font-display m-0 uppercase" aria-hidden="true">
          <span class="project-title-reveal__inner">Flou</span>
        </p>
        <ul class="flou-tags" aria-label="Project tags">
          <li>Branding</li>
          <li>Art direction</li>
          <li>Visual identity</li>
        </ul>
        <div class="flou-meta" aria-label="Project details">
          <p><i>Client: </i>Flouwers</p>
          <p><i>Sector: </i>Floral scenography</p>
          <p><i>Country: </i>Belgium</p>
          <p>
            <i>Instagram: </i>
            <a href="https://www.instagram.com/f.lou.wers/" target="_blank" rel="noopener noreferrer">@f.lou.wers</a>
          </p>
        </div>
      </header>
    </aside>

    <div class="flou-main-flow">
      <figure class="flou-hero">
        <ResponsiveImage
          src={flouHero}
          alt="Flou floral identity cover"
          sizes="(min-width: 1280px) 64vw, (min-width: 970px) calc(100vw - 24rem), calc(100vw - 2rem)"
          loading="eager"
          fetchpriority="high"
          class="flou-hero-picture"
          imgClass="flou-hero-img"
        />
      </figure>

      <section class="flou-study-card masonry-reveal" aria-label="Flou case study">
        <article class="flou-block">
          <h2 class="flou-block__title">Project</h2>
          <hr class="flou-block__rule" />
          <div class="flou-block__body">
            {projectParagraphs.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </article>

        <article class="flou-block">
          <h2 class="flou-block__title">Branding</h2>
          <hr class="flou-block__rule" />
          <div class="flou-block__body">
            {brandingParagraphs.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </article>

        <article class="flou-block">
          <h2 class="flou-block__title">Responsibilities</h2>
          <hr class="flou-block__rule" />
          <div class="flou-block__body">
            <p>Visual identity - Art direction</p>
          </div>
        </article>
      </section>

      <figure class="flou-wide masonry-reveal">
        <ResponsiveImage
          src={pic('group-109')}
          alt="Flou floral logo over a blurred bouquet"
          sizes="(min-width: 1280px) 64vw, (min-width: 970px) calc(100vw - 24rem), calc(100vw - 2rem)"
          loading="lazy"
          fetchpriority="low"
          imgClass="flou-wide-img"
        />
      </figure>

      <section
        class="flou-masonry"
        data-masonry
        data-cols-desktop="3"
        data-cols-tablet="2"
        data-cols-mobile="1"
        aria-label="Flou visual identity gallery"
      >
        {
          flouImages.map((img, i) => (
            <article class="masonry-item masonry-reveal" style={`--reveal-delay: ${delay(i)}`}>
              <ResponsiveImage
                src={pic(img.base)}
                alt={img.alt}
                sizes={masonrySizes}
                loading="lazy"
                fetchpriority="low"
                imgClass={`flou-masonry-media${img.noRadius ? ' no-radius' : ''}`}
              />
            </article>
          ))
        }
      </section>

      <figure class="flou-final masonry-reveal">
        <ResponsiveImage
          src={pic('flou-brandbook')}
          alt="Flou brandbook"
          sizes="(min-width: 1280px) 64vw, (min-width: 970px) calc(100vw - 24rem), calc(100vw - 2rem)"
          loading="lazy"
          fetchpriority="low"
          imgClass="flou-final-img"
        />
      </figure>
    </div>
  </div>
</section>

<script>
  import '../../scripts/masonry-columns.ts';
  import '../../scripts/masonry-reveal.ts';
</script>

<style>
  :global(.project-detail-page) > .flou-project {
    width: 100%;
    max-width: min(100%, 1680px);
    margin-inline: auto;
    padding-inline: 20px;
    padding-block: clamp(0.5rem, 2vw, 1.5rem);
  }

  .flou-layout {
    display: grid;
    grid-template-columns: minmax(18rem, 0.72fr) minmax(0, 1.58fr);
    gap: clamp(2rem, 4vw, 5rem);
    align-items: start;
  }

  .flou-sticky {
    position: sticky;
    top: clamp(1rem, 3vw, 2.5rem);
    min-width: 0;
  }

  .flou-headline {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .flou-title {
    max-width: 8ch;
    color: var(--text-primary);
    font-size: clamp(2.8rem, 6vw, 5.2rem);
    line-height: 0.92;
  }

  .flou-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .flou-tags li {
    border: 1px solid currentColor;
    border-radius: 999px;
    padding: 0.42rem 0.7rem;
    color: var(--text-primary);
    font-family: var(--font-family-display);
    font-size: 0.78rem;
    line-height: 1;
    text-transform: uppercase;
  }

  .flou-meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    max-width: 31ch;
    color: var(--text-secondary);
    font-family: var(--font-family-body);
    font-size: 0.95rem;
    font-weight: 300;
    line-height: 1.45;
  }

  .flou-meta p {
    margin: 0;
  }

  .flou-meta i {
    color: var(--text-primary);
    font-style: italic;
    text-transform: uppercase;
  }

  .flou-meta a {
    color: inherit;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.16em;
  }

  .flou-main-flow {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: clamp(2.4rem, 6vw, 4.5rem);
  }

  .flou-hero {
    overflow: hidden;
    width: 100%;
    margin: 0;
    border-radius: var(--project-card-radius);
    background: #fff;
    box-shadow:
      0 18px 42px rgba(35, 35, 35, 0.12),
      0 4px 12px rgba(35, 35, 35, 0.07);
  }

  .flou-hero :global(.flou-hero-picture) {
    display: block;
  }

  .flou-hero :global(.flou-hero-img) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0;
    background: #fff;
  }

  .flou-study-card {
    display: flex;
    width: 100%;
    flex-direction: column;
    gap: clamp(2.4rem, 6vw, 4.5rem);
    padding: clamp(1.4rem, 2.8vw, 2.4rem);
    margin-block: clamp(0.4rem, 1.6vw, 1.4rem);
    background: var(--palette-white);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
  }

  .flou-block__title {
    margin: 0;
    color: var(--text-primary);
    font-family: var(--font-family-display);
    font-size: clamp(1.1rem, 1.9vw, 1.7rem);
    font-weight: 400;
    letter-spacing: 0.04em;
    line-height: 1.05;
    text-transform: uppercase;
  }

  .flou-block__rule {
    width: 100%;
    height: 0;
    margin: clamp(0.8rem, 1.6vw, 1.2rem) 0 clamp(1.2rem, 2.6vw, 2rem);
    border: 0;
    border-top: 1px solid color-mix(in srgb, var(--text-primary) 26%, transparent);
  }

  .flou-block__body {
    display: flex;
    width: min(100%, 62ch);
    margin-left: auto;
    flex-direction: column;
    gap: 1rem;
    color: var(--text-secondary);
    font-family: var(--font-family-body);
    font-weight: 300;
  }

  .flou-block__body p {
    margin: 0;
    font-size: 1rem;
    line-height: 1.65;
  }

  .flou-masonry {
    display: flex;
    gap: clamp(0.75rem, 1.8vw, 1rem);
    align-items: flex-start;
    border-radius: var(--project-card-radius);
  }

  .flou-masonry :global(.masonry-col) {
    flex: 1 1 0;
    min-width: 0;
  }

  .flou-masonry :global(.flou-masonry-media) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--project-card-radius);
    background: #fff;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
  }

  .flou-masonry :global(.flou-masonry-media.no-radius) {
    border-radius: 0;
  }

  .flou-wide,
  .flou-final {
    margin: 0;
    overflow: hidden;
    width: 100%;
    border-radius: var(--project-card-radius);
    background: #fff;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
  }

  .flou-wide :global(.flou-wide-img),
  .flou-final :global(.flou-final-img) {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (max-width: 960px) {
    .flou-layout {
      grid-template-columns: 1fr;
      gap: clamp(1.5rem, 5vw, 3rem);
    }

    .flou-sticky {
      position: static;
    }

    .flou-title {
      max-width: none;
      font-size: clamp(2.7rem, 15vw, 4.8rem);
    }

    .flou-meta,
    .flou-block__body {
      max-width: none;
      width: 100%;
      margin-left: 0;
    }
  }

  @media (max-width: 628px) {
    .flou-masonry {
      flex-direction: column;
      gap: 0.75rem;
    }

    .flou-study-card {
      gap: 2rem;
    }
  }
</style>
