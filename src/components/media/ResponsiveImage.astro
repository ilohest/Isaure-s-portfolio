---
// Version .astro de ResponsiveImage (pour pages/composants .astro statiques).
// `img` = import vite-imagetools `&as=picture` :
//   { sources: { avif?, webp? }, img: { src, w, h } }
interface PictureImport {
  sources: { avif?: string; webp?: string };
  img: { src: string; w: number; h: number };
}

interface Props {
  img: PictureImport;
  alt: string;
  sizes?: string;
  class?: string;
  imgClass?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
}

const {
  img,
  alt,
  sizes = '100vw',
  class: pictureClass,
  imgClass,
  loading = 'lazy',
  fetchpriority = 'auto',
} = Astro.props;
---

<picture class={pictureClass}>
  {img.sources.avif && <source type="image/avif" srcset={img.sources.avif} sizes={sizes} />}
  {img.sources.webp && <source type="image/webp" srcset={img.sources.webp} sizes={sizes} />}
  <img
    src={img.img.src}
    width={img.img.w}
    height={img.img.h}
    alt={alt}
    class={imgClass}
    loading={loading}
    fetchpriority={fetchpriority}
    decoding="async"
  />
</picture>
