---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageSeo from '../../../components/seo/PageSeo.astro';
import ProjectJsonLd from '../../../components/seo/ProjectJsonLd.astro';
import { webDevelopmentPages } from '../../../../site-pages';
import allProjects from '@/all-projects';
import AverysProject from '../../../components/web-dev/AverysProject.astro';
import ClientLawyerPlatformProject from '../../../components/web-dev/ClientLawyerPlatformProject.astro';
import GoaKombuchaFlowProject from '../../../components/web-dev/GoaKombuchaFlowProject.astro';
import BodaCarmenNestorProject from '../../../components/web-dev/BodaCarmenNestorProject.astro';
import BodaMartaPedroProject from '../../../components/web-dev/BodaMartaPedroProject.astro';
import LouisCattiauxProject from '../../../components/web-dev/LouisCattiauxProject.astro';
import HamburgerProject from '../../../components/web-dev/HamburgerProject.astro';
import LaPetiteSerreUrbaineProject from '../../../components/web-dev/LaPetiteSerreUrbaineProject.astro';
import AcademieCleDoReProject from '../../../components/web-dev/AcademieCleDoReProject.astro';
import CreydaProject from '../../../components/web-dev/CreydaProject.astro';
import GradientProject from '../../../components/web-dev/GradientProject.astro';
import JohnScissorsProject from '../../../components/web-dev/JohnScissorsProject.astro';
import BellelachaiseProject from '../../../components/web-dev/BellelachaiseProject.astro';
import BodaLisPavlosProject from '../../../components/web-dev/BodaLisPavlosProject.astro';
import CanprunaProject from '../../../components/web-dev/CanprunaProject.astro';
import DidacmaniaProject from '../../../components/web-dev/DidacmaniaProject.astro';
import TrancheDeCakeProject from '../../../components/web-dev/TrancheDeCakeProject.astro';

// Map slug → composant projet (.astro). Enrichi au fil du portage.
const componentBySlug = {
  averys: AverysProject,
  'client-lawyer-platform': ClientLawyerPlatformProject,
  'goa-kombucha-flow': GoaKombuchaFlowProject,
  'boda-carmen-nestor': BodaCarmenNestorProject,
  'boda-marta-y-pedro': BodaMartaPedroProject,
  'louis-cattiaux': LouisCattiauxProject,
  'the-perfect-hamburger': HamburgerProject,
  'la-petite-serre-urbaine': LaPetiteSerreUrbaineProject,
  'academie-cle-do-re': AcademieCleDoReProject,
  creyda: CreydaProject,
  gradient: GradientProject,
  'john-scissors': JohnScissorsProject,
  bellelachaise: BellelachaiseProject,
  'boda-lis-pavlos': BodaLisPavlosProject,
  'canpruna-accomodation': CanprunaProject,
  didacmania: DidacmaniaProject,
  'tranche-de-cake': TrancheDeCakeProject,
} as const;

export function getStaticPaths() {
  const ported = new Set([
    'averys',
    'client-lawyer-platform',
    'goa-kombucha-flow',
    'boda-carmen-nestor',
    'boda-marta-y-pedro',
    'louis-cattiaux',
    'the-perfect-hamburger',
    'la-petite-serre-urbaine',
    'academie-cle-do-re',
    'creyda',
    'gradient',
    'john-scissors',
    'bellelachaise',
    'boda-lis-pavlos',
    'canpruna-accomodation',
    'didacmania',
    'tranche-de-cake',
  ]);
  const sorted = [...allProjects].sort((a, b) => a.order - b.order);

  return Object.entries(webDevelopmentPages)
    .filter(([slug]) => ported.has(slug))
    .map(([slug, page]) => {
      const idx = sorted.findIndex((p) => p.projectLink === page.path);
      const prev = idx > 0 ? sorted[idx - 1] : null;
      const next = idx >= 0 && idx < sorted.length - 1 ? sorted[idx + 1] : null;
      const title = page.title.replace(/ — Web Development — Isaure Lohest$/, '');
      return {
        params: { slug },
        props: { slug, page, title, prevHref: prev?.projectLink ?? null, nextHref: next?.projectLink ?? null },
      };
    });
}

const { slug, page, title, prevHref, nextHref } = Astro.props;
const Project = componentBySlug[slug as keyof typeof componentBySlug];
---

<BaseLayout title={page.title}>
  <PageSeo slot="head" title={page.title} description={page.description} robots={page.robots} />
  <ProjectJsonLd
    slot="head"
    title={title}
    description={page.description}
    path={page.path}
    sectionLabel="Web Development"
    sectionPath="/achievements/web-developement"
    projectType="Web development project"
  />

  <div class="project-detail-page">
    <a href="/achievements" class="back-project-float">Back to projects</a>

    <Project />

    <nav class="project-nav container mx-auto px-4" aria-label="Project navigation">
      {prevHref ? (
        <a href={prevHref} class="project-nav-arrow project-nav-arrow-prev" aria-label="Previous project">
          <span aria-hidden="true">←</span>
        </a>
      ) : (
        <span></span>
      )}

      <span class="project-nav-title">{title}</span>

      {nextHref ? (
        <a href={nextHref} class="project-nav-arrow project-nav-arrow-next" aria-label="Next project">
          <span aria-hidden="true">→</span>
        </a>
      ) : (
        <span></span>
      )}
    </nav>

    <section class="project-detail-cta container mx-auto px-4" aria-label="Work with me">
      <a href="/contact" class="portfolio-pill-link">Work with me</a>
    </section>
  </div>
</BaseLayout>

<script>
  import '../../../scripts/project-back-button.ts';
</script>
