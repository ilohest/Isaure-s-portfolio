---
import { standalonePages } from '../../site-pages';
const page = standalonePages.cv;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{page.title}</title>
    <meta name="description" content={page.description} />
    <meta name="robots" content="index, follow" />
  </head>
  <body>
    <div class="cv-route">
      <iframe class="cv-route__frame" src="/cv-isaure-lohest.html" title="CV Isaure Lohest d'Hooghvorst"></iframe>
    </div>

    <style>
      html,
      body {
        margin: 0;
      }
      .cv-route {
        width: 100%;
        min-height: 100vh;
        background: #faf9f5;
      }
      .cv-route__frame {
        display: block;
        width: 100%;
        height: 100vh;
        border: 0;
        background: #faf9f5;
      }
    </style>
  </body>
</html>
