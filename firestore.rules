rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /contactMessages/{docId} {
      allow create: if
        request.resource.data.keys().hasOnly([
          'name',
          'email',
          'phoneNumber',
          'contactMethod',
          'projectType',
          'numberOfPages',
          'features',
          'featuresOther',
          'visualIdentity',
          'deadline',
          'additionalInfo',
          'createdAt'
        ]) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() >= 2 &&
        request.resource.data.name.size() <= 120 &&
        request.resource.data.email is string &&
        request.resource.data.email.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$') &&
        request.resource.data.email.size() <= 200 &&
        request.resource.data.contactMethod is string &&
        request.resource.data.contactMethod in ['email', 'phone'] &&
        request.resource.data.projectType is string &&
        request.resource.data.projectType.size() <= 80 &&
        request.resource.data.numberOfPages is string &&
        request.resource.data.numberOfPages in ['1', '1-5', '6-10', '11+'] &&
        request.resource.data.visualIdentity is string &&
        request.resource.data.visualIdentity in ['', 'yes', 'no'] &&
        request.resource.data.deadline is string &&
        request.resource.data.deadline in ['urgent', 'short-term', 'flexible'] &&
        request.resource.data.additionalInfo is string &&
        request.resource.data.additionalInfo.size() <= 5000 &&
        (
          !(request.resource.data.phoneNumber is string) ||
          request.resource.data.phoneNumber.size() <= 40
        ) &&
        (
          !(request.resource.data.featuresOther is string) ||
          request.resource.data.featuresOther.size() <= 200
        ) &&
        request.resource.data.features is list &&
        request.resource.data.features.size() <= 12;
      allow read, update, delete: if false;
    }
  }
}
